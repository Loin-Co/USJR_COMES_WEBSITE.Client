@* Skeleton placeholder matching the Management Officers grid card layout *@
<div style="display: flex; flex-wrap: wrap; gap: 16px; padding: 8px 0;">
    @for (int i = 0; i < Count; i++)
    {
        <div style="display: flex; flex-direction: column; gap: 10px; width: 160px; padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.04);">
            <div class="skeleton" style="width: 100%; height: 140px; border-radius: 6px;"></div>
            <div class="skeleton" style="height: 13px; width: 75%;"></div>
            <div class="skeleton" style="height: 11px; width: 60%;"></div>
            <div style="display: flex; gap: 8px; justify-content: flex-end; margin-top: 2px;">
                <div class="skeleton" style="width: 26px; height: 26px; border-radius: 6px;"></div>
                <div class="skeleton" style="width: 26px; height: 26px; border-radius: 6px;"></div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Count { get; set; } = 4;
}
