@* Skeleton placeholder matching the Officers page alternating card layout *@
@for (int i = 0; i < Count; i++)
{
    <div class="officer-card @(i % 2 == 0 ? "image-left" : "image-right")" style="pointer-events: none;">
        <div class="officer-image-col">
            <div class="officer-image-box">
                <div class="skeleton" style="width: 100%; height: 100%; min-height: 220px; border-radius: 8px;"></div>
            </div>
        </div>
        <div class="officer-text" style="display: flex; flex-direction: column; gap: 14px; justify-content: center;">
            <div class="skeleton" style="height: 12px; width: 90%;"></div>
            <div class="skeleton" style="height: 12px; width: 80%;"></div>
            <div class="skeleton" style="height: 12px; width: 70%;"></div>
            <div class="skeleton" style="height: 18px; width: 55%;"></div>
            <div class="skeleton" style="height: 12px; width: 85%;"></div>
        </div>
    </div>
}

@code {
    [Parameter] public int Count { get; set; } = 3;
}
