@* Skeleton placeholder matching the Upcoming Events card layout *@
<div style="display: flex; flex-direction: column; gap: 12px;">
    @for (int i = 0; i < Count; i++)
    {
        <div class="event-card" style="pointer-events: none; overflow: hidden;">
            <div class="skeleton" style="height: 150px; border-radius: 6px 6px 0 0;"></div>
            <div style="padding: 12px; display: flex; flex-direction: column; gap: 8px;">
                <div class="skeleton" style="height: 13px; width: 85%;"></div>
                <div class="skeleton" style="height: 11px; width: 60%;"></div>
                <div class="skeleton" style="height: 11px; width: 70%;"></div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Count { get; set; } = 3;
}
