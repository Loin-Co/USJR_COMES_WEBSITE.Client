@* Skeleton placeholder matching the Home hero slider layout *@
<div class="hero-slider" style="pointer-events: none;">
    <div style="position: relative; overflow: hidden;">
        <div class="skeleton" style="height: 400px; border-radius: 0;"></div>
        <div style="position: absolute; bottom: 3rem; left: 2rem; right: 2rem; display: flex; flex-direction: column; gap: 14px; z-index: 1;">
            <div class="skeleton" style="height: 32px; width: 55%;"></div>
            <div class="skeleton" style="height: 16px; width: 38%;"></div>
            <div class="skeleton" style="height: 36px; width: 120px; border-radius: 20px;"></div>
        </div>
        <div style="position: absolute; bottom: 1.2rem; right: 2rem; display: flex; align-items: center; gap: 8px; z-index: 1;">
            @for (int i = 0; i < 3; i++)
            {
                <div class="skeleton skeleton-circle" style="width: 10px; height: 10px;"></div>
            }
        </div>
    </div>
</div>
