@inject IOfflineSyncService OfflineSync
@implements IDisposable

@if (!OfflineSync.IsOnline)
{
    <div class="offline-banner">
        <span class="offline-banner-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="1" y1="1" x2="23" y2="23"></line>
                <path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"></path>
                <path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"></path>
                <path d="M10.71 5.05A16 16 0 0 1 22.56 9"></path>
                <path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"></path>
                <path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path>
                <line x1="12" y1="20" x2="12.01" y2="20"></line>
            </svg>
        </span>
        <span>
            You're offline
            @if (OfflineSync.PendingCount > 0)
            {
                <span> — <strong>@OfflineSync.PendingCount change@(OfflineSync.PendingCount == 1 ? "" : "s")</strong> will sync when reconnected</span>
            }
            else
            {
                <span> — browsing in read-only mode</span>
            }
        </span>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        OfflineSync.OnChange += HandleChange;
    }

    private void HandleChange() => InvokeAsync(StateHasChanged);

    public void Dispose() => OfflineSync.OnChange -= HandleChange;
}

<style>
    .offline-banner {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 9999;
        background: rgba(234, 179, 8, 0.92);
        color: #1c1400;
        font-size: 0.8rem;
        font-weight: 500;
        padding: 0.45rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        backdrop-filter: blur(4px);
        border-bottom: 1px solid rgba(161, 120, 0, 0.5);
        animation: slide-down 0.25s ease;
    }

    .offline-banner-icon {
        display: flex;
        align-items: center;
        flex-shrink: 0;
    }

    @@keyframes slide-down {
        from { transform: translateY(-100%); }
        to   { transform: translateY(0); }
    }
</style>
