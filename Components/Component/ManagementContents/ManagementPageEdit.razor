    private async Task HandleBgImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        _bgImageUploadStatus = "Processing...";
        StateHasChanged();
        try
        {
            using var ms = new System.IO.MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 8 * 1024 * 1024).CopyToAsync(ms);
            var bytes = ms.ToArray();
            _bgImageBase64 = Convert.ToBase64String(bytes);
            _bgImageMimeType = file.ContentType;
            _bgImagePreviewDataUrl = $"data:{file.ContentType};base64,{_bgImageBase64}";
            _bgType = "image";
            _clearBgImage = false;
            _bgImageUploadStatus = "Image ready.";
            Preview();
        }
        catch { _bgImageUploadStatus = "Upload failed. Max 8 MB."; }
    }

    private async Task HandleLogoUpload(InputFileChangeEventArgs e)
