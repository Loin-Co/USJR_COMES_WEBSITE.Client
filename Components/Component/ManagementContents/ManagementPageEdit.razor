@using Microsoft.AspNetCore.Components.Forms
@using USJR_COMES_WEBSITE.Services
@using USJR_COMES_WEBSITE.ViewModels
@using USJR_COMES_WEBSITE.APIs
@inject ISiteSettingsService SettingsService
@inject IJSRuntime JS
@inject USJR_COMES_WEBSITE.Services.UserStateService UserState
@inject IHttpClientFactory HttpClientFactory

<div class="page-edit-wrap">
    <div class="page-edit-header">
        <h2 class="page-edit-title">Page Edit</h2>
        @if (CanDirectSave)
        {
            <p class="page-edit-subtitle">Customize the site appearance. Changes preview in the panel on the right — click Save to apply site-wide.</p>
        }
        else
        {
            <p class="page-edit-subtitle">Customize the site appearance. Changes preview in the panel on the right and won't go live until an adviser approves.</p>
        }
    </div>

    <!-- Tab selector -->
    <div class="pe-tabs">
        <button class="pe-tab @(_tab == "bg" ? "active" : "")" @onclick='() => _tab = "bg"'>Background 1</button>
        <button class="pe-tab @(_tab == "pattern" ? "active" : "")" @onclick='() => _tab = "pattern"'>Background 2</button>
        <button class="pe-tab @(_tab == "nav" ? "active" : "")" @onclick='() => _tab = "nav"'>Navbar</button>
        <button class="pe-tab @(_tab == "header" ? "active" : "")" @onclick='() => _tab = "header"'>Header</button>
        <button class="pe-tab @(_tab == "footer" ? "active" : "")" @onclick='() => _tab = "footer"'>Footer</button>
        <button class="pe-tab @(_tab == "robot" ? "active" : "")" @onclick='() => _tab = "robot"'>Robot</button>
        <button class="pe-tab @(_tab == "theme" ? "active" : "")" @onclick='() => _tab = "theme"'>Theme</button>
    </div>

    <div class="pe-body">
    <div class="pe-controls">

    <!-- ── BACKGROUND TAB ── -->
    @if (_tab == "bg")
    {
        <div class="pe-section">
            <div class="pe-type-row">
                <button class="pe-type-btn @(_bgType == "color" ? "active" : "")" @onclick='() => SetBgType("color")'>Color</button>
                <button class="pe-type-btn @(_bgType == "gradient" ? "active" : "")" @onclick='() => SetBgType("gradient")'>Gradient</button>
                <button class="pe-type-btn @(_bgType == "image" ? "active" : "")" @onclick='() => SetBgType("image")'>Image</button>
            </div>

            @if (_bgType == "color")
            {
                <div class="pe-section-label" style="margin-top:1.25rem;">Theme Presets</div>
                <div class="pe-presets-grid">
                    @foreach (var p in _colorPresets)
                    {
                        <button class="pe-preset-swatch @(_activeKey == p.Key ? "active" : "")"
                                style="background: @p.Preview" title="@p.Label"
                                @onclick="() => ApplyColorPreset(p)">
                            <span class="pe-preset-label">@p.Label</span>
                        </button>
                    }
                </div>
                <div class="pe-section-label" style="margin-top:1.25rem;">Custom Color</div>
                <div class="pe-custom-color-row">
                    <input type="color" class="pe-color-input" value="@_bgColor"
                           @oninput="OnBgColorInput" />
                    <span class="pe-color-hex">@_bgColor</span>
                </div>
            }

            @if (_bgType == "gradient")
            {
                <div class="pe-section-label" style="margin-top:1.25rem;">Gradient Presets</div>
                <div class="pe-presets-grid">
                    @foreach (var g in _gradientPresets)
                    {
                        <button class="pe-preset-swatch @(_activeKey == g.Key ? "active" : "")"
                                style="background: @g.Preview" title="@g.Label"
                                @onclick="() => ApplyGradientPreset(g)">
                            <span class="pe-preset-label">@g.Label</span>
                        </button>
                    }
                </div>
            }

            @if (_bgType == "image")
            {
                <div class="pe-section-label" style="margin-top:1.25rem;">Upload Image</div>
                <InputFile OnChange="HandleBgImageUpload" accept="image/*" class="pe-file-input" />
                @if (!string.IsNullOrEmpty(_bgImageUploadStatus))
                {
                    <div class="pe-upload-status">@_bgImageUploadStatus</div>
                }
                @if (_hasBgImage || !string.IsNullOrEmpty(_bgImagePreviewDataUrl))
                {
                    <div class="pe-image-preview-row">
                        <img src="@(_bgImagePreviewDataUrl.Length > 0 ? _bgImagePreviewDataUrl : ApiEndpoints.SiteSettings.BackgroundImage)"
                             class="pe-image-thumb" alt="bg preview" />
                        <button class="pe-clear-btn" @onclick="ClearBgImage">Remove Image</button>
                    </div>
                }

                <div class="pe-section-label" style="margin-top:1.25rem;">Aspect / Size</div>
                <select class="pe-select" @bind="_bgSize" @bind:after="Preview">
                    <option value="cover">Cover (fill, may crop)</option>
                    <option value="contain">Contain (fit, no crop)</option>
                    <option value="auto">Auto (original size)</option>
                    <option value="100% 100%">Stretch (fill exactly)</option>
                    <option value="custom">Custom (set px / %)</option>
                </select>

                @if (_bgSize == "custom")
                {
                    <div class="pe-size-custom-row">
                        <div class="pe-size-custom-field">
                            <label class="pe-size-label">Width</label>
                            <input type="number" class="pe-number-input" value="@_bgCustomW"
                                   min="1" max="9999"
                                   @oninput="OnBgCustomWInput" />
                            <span class="pe-size-unit">%</span>
                        </div>
                        <div class="pe-size-custom-field">
                            <label class="pe-size-label">Height</label>
                            <input type="number" class="pe-number-input" value="@_bgCustomH"
                                   min="1" max="9999"
                                   @oninput="OnBgCustomHInput" />
                            <span class="pe-size-unit">%</span>
                        </div>
                    </div>
                    <p class="pe-hint">e.g. 120 × 80 renders as <code>120% 80%</code></p>
                }

                <div class="pe-section-label" style="margin-top:1rem;">Position</div>
                <select class="pe-select" @bind="_bgPosition" @bind:after="Preview">
                    <option value="center">Center</option>
                    <option value="top">Top</option>
                    <option value="bottom">Bottom</option>
                    <option value="left">Left</option>
                    <option value="right">Right</option>
                    <option value="top left">Top Left</option>
                    <option value="top right">Top Right</option>
                    <option value="bottom left">Bottom Left</option>
                    <option value="bottom right">Bottom Right</option>
                </select>

                <div class="pe-section-label" style="margin-top:1rem;">Opacity <span class="pe-range-val">@(_bgOpacity.ToString("P0"))</span></div>
                <input type="range" min="0.05" max="1" step="0.05"
                       class="pe-range"
                       value="@_bgOpacity"
                       @oninput="OnOpacityInput" />
            }
        </div>
    }

    <!-- ── PATTERN TAB (Background 2) ── -->
    @if (_tab == "pattern")
    {
        <div class="pe-section">
            <p class="pe-hint" style="margin-bottom:1.25rem;">
                Background 2 overlays on top of Background 1. Choose a pattern or set it to None.
            </p>
            <div class="pe-pattern-grid">
                @foreach (var p in _patternPresets)
                {
                    <button class="pe-pattern-card @(_bgPattern == p.Key ? "active" : "")"
                            @onclick="() => SetPattern(p.Key)">
                        <div class="pe-pattern-preview @("pprev-" + p.Key)"></div>
                        <span class="pe-pattern-label">@p.Label</span>
                    </button>
                }
            </div>
        </div>
    }

    <!-- ── NAVBAR TAB ── -->
    @if (_tab == "nav")
    {
        <div class="pe-section">
            <div class="pe-section-label">Navbar Background Color</div>
            <p class="pe-hint">Leave blank to use the default dark green. Supports any CSS color (hex, rgba, etc.)</p>
            <div class="pe-custom-color-row">
                <input type="color" class="pe-color-input" value="@_navbarColor"
                       @oninput="OnNavbarColorInput" />
                <span class="pe-color-hex">@_navbarColor</span>
                <button class="pe-clear-btn" @onclick="ClearNavbarColor">Reset to Default</button>
            </div>
            <div class="pe-section-label" style="margin-top:1.5rem;">Navbar Presets</div>
            <div class="pe-presets-grid">
                @foreach (var p in _navbarPresets)
                {
                    <button class="pe-preset-swatch @(_navbarColor == p.Value ? "active" : "")"
                            style="background: @p.Value" title="@p.Label"
                            @onclick="() => ApplyNavbarPreset(p.Value)">
                        <span class="pe-preset-label">@p.Label</span>
                    </button>
                }
            </div>
        </div>
    }

    <!-- ── HEADER TAB ── -->
    @if (_tab == "header")
    {
        <div class="pe-section">
            <div class="pe-section-label">Organization Name</div>
            <input type="text" class="pe-text-input" value="@_headerOrgName"
                   @oninput="OnHeaderOrgNameInput" placeholder="Organization name shown at top" maxlength="200" />

            <div class="pe-section-label" style="margin-top:1.25rem;">Tagline / Quote</div>
            <input type="text" class="pe-text-input" value="@_headerOrgQuote"
                   @oninput="OnHeaderOrgQuoteInput" placeholder="Tagline shown below the org name" maxlength="500" />

            <div class="pe-section-label" style="margin-top:1.25rem;">Header Logo</div>
            <InputFile OnChange="HandleLogoUpload" accept="image/*" class="pe-file-input" />
            @if (!string.IsNullOrEmpty(_logoUploadStatus))
            {
                <div class="pe-upload-status">@_logoUploadStatus</div>
            }
            @if (_hasHeaderLogo || !string.IsNullOrEmpty(_logoPreviewDataUrl))
            {
                <div class="pe-image-preview-row">
                    <img src="@(_logoPreviewDataUrl.Length > 0 ? _logoPreviewDataUrl : ApiEndpoints.SiteSettings.HeaderLogo)"
                         class="pe-logo-thumb" alt="logo preview" />
                    <button class="pe-clear-btn" @onclick="ClearHeaderLogo">Remove Logo</button>
                </div>
            }
            <p class="pe-hint">If no logo is uploaded, the default COMES SVG logo is used.</p>

            <div class="pe-section-label" style="margin-top:1.5rem;">Header Logo Size <span class="pe-range-val">@_headerLogoHeight px</span></div>
            <div class="pe-size-slider-row">
                <input type="range" min="10" max="400" step="1"
                       class="pe-range"
                       value="@_headerLogoHeight"
                       @oninput="OnHeaderLogoHeightInput" />
                <input type="number" class="pe-number-input" value="@_headerLogoHeight"
                       min="10" max="400"
                       @oninput="OnHeaderLogoHeightInput" />
                <span class="pe-size-unit">px</span>
            </div>

        </div>
    }

    <!-- ── FOOTER TAB ── -->
    @if (_tab == "footer")
    {
        <div class="pe-section">
            <div class="pe-section-label">Footer Logo Size <span class="pe-range-val">@_footerLogoHeight px</span></div>
            <div class="pe-size-slider-row">
                <input type="range" min="10" max="300" step="1"
                       class="pe-range"
                       value="@_footerLogoHeight"
                       @oninput="OnFooterLogoHeightInput" />
                <input type="number" class="pe-number-input" value="@_footerLogoHeight"
                       min="10" max="300"
                       @oninput="OnFooterLogoHeightInput" />
                <span class="pe-size-unit">px</span>
            </div>

            <div class="pe-section-label" style="margin-top:1.25rem;">Footer Subtitle</div>
            <input type="text" class="pe-text-input" value="@_footerOrgSub"
                   @oninput="OnFooterOrgSubInput" placeholder="Subtitle shown under the org name" maxlength="500" />

            <div class="pe-section-label" style="margin-top:1.25rem;">Facebook URL</div>
            <input type="url" class="pe-text-input" value="@_footerFacebookUrl"
                   @oninput="OnFooterFacebookUrlInput" placeholder="https://www.facebook.com/..." maxlength="500" />

            <div class="pe-section-label" style="margin-top:1.25rem;">Website URL</div>
            <input type="url" class="pe-text-input" value="@_footerWebsiteUrl"
                   @oninput="OnFooterWebsiteUrlInput" placeholder="https://..." maxlength="500" />
        </div>
    }

    <!-- ── ROBOT TAB ── -->
    @if (_tab == "robot")
    {
        <div class="pe-section">
            <p class="pe-hint" style="margin-bottom:1.25rem;">
                Edit the text shown in the hero section on the home page.
            </p>

            <div class="pe-section-label">Overlay Text (ADELANTE)</div>
            <input type="text" class="pe-text-input" value="@_robotAdelanteText"
                   @oninput="OnRobotAdelanteInput" placeholder="e.g. ADELANTE" maxlength="200" />

            <div class="pe-section-label" style="margin-top:1.25rem;">Society Strip Text</div>
            <input type="text" class="pe-text-input" value="@_robotSocietyText"
                   @oninput="OnRobotSocietyInput" placeholder="e.g. USJ-R Computer Engineering Society" maxlength="200" />

            <div class="pe-section-label" style="margin-top:1.25rem;">Abbreviation (CpES)</div>
            <input type="text" class="pe-text-input" value="@_robotAbbreviation"
                   @oninput="OnRobotAbbreviationInput" placeholder="e.g. CpES" maxlength="50" />

            <div class="pe-section-label" style="margin-top:1.25rem;">Tagline</div>
            <p class="pe-hint">Use new lines to break text (each line renders on its own row).</p>
            <textarea class="pe-text-input" rows="4"
                      @oninput="OnRobotTaglineInput"
                      placeholder="e.g. BUILDING THE&#10;FUTURE&#10;THROUGH&#10;ENGINEERING">@_robotTagline</textarea>
        </div>
    }

    <!-- ── THEME TAB ── -->
    @if (_tab == "theme")
    {
        <div class="pe-section">
            <p class="pe-hint" style="margin-bottom:1.25rem;">
                Customize the site's accent color, text color, and font. Changes preview immediately; click Save to apply site-wide.
            </p>

            <div class="pe-section-label">Color Theme Presets</div>
            <div class="pe-presets-grid">
                @foreach (var p in _themePresets)
                {
                    <button class="pe-preset-swatch @(_themePresetKey == p.Key ? "active" : "")"
                            style="background: linear-gradient(135deg, @p.Accent 0%, @p.AccentBright 100%);"
                            title="@p.Label"
                            @onclick="() => ApplyThemePreset(p)">
                        <span class="pe-preset-label">@p.Label</span>
                    </button>
                }
            </div>

            <div class="pe-section-label" style="margin-top:1.5rem;">Accent Color</div>
            <div class="pe-custom-color-row">
                <input type="color" class="pe-color-input" value="@_themeAccent"
                       @oninput="OnThemeAccentInput" />
                <span class="pe-color-hex">@_themeAccent</span>
            </div>

            <div class="pe-section-label" style="margin-top:1.25rem;">Highlight / Bright Color</div>
            <div class="pe-custom-color-row">
                <input type="color" class="pe-color-input" value="@_themeAccentBright"
                       @oninput="OnThemeAccentBrightInput" />
                <span class="pe-color-hex">@_themeAccentBright</span>
            </div>

            <div class="pe-section-label" style="margin-top:1.25rem;">Text Color</div>
            <div class="pe-custom-color-row">
                <input type="color" class="pe-color-input" value="@_themeTextColor"
                       @oninput="OnThemeTextColorInput" />
                <span class="pe-color-hex">@_themeTextColor</span>
            </div>

            <div class="pe-section-label" style="margin-top:1.5rem;">Font Family</div>
            <select class="pe-select" value="@_themeFontFamily"
                    @onchange="OnThemeFontFamilyChange">
                <option value="default">Default (System)</option>
                <option value="inter">Inter</option>
                <option value="roboto">Roboto</option>
                <option value="orbitron">Orbitron</option>
                <option value="sharetech">Share Tech Mono</option>
                <option value="exo2">Exo 2</option>
                <option value="pressstart">Press Start 2P</option>
            </select>

            <div class="pe-section-label" style="margin-top:1.25rem;">Font Size <span class="pe-range-val">@_themeFontSize%</span></div>
            <input type="range" min="80" max="130" step="5"
                   class="pe-range"
                   value="@_themeFontSize"
                   @oninput="OnThemeFontSizeInput" />
            <p class="pe-hint">Default is 100%. Adjust for accessibility or personal preference.</p>
        </div>
    }

    </div><!-- /pe-controls -->

    <!-- ── PREVIEW COLUMN ── -->
    <div class="pe-preview-column">
        <div class="pe-preview-panel">
            <div class="pe-preview-label-row">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <span class="pe-preview-title">Preview</span>
                <span class="pe-preview-hint">Changes only appear here until submitted</span>
            </div>
            <div class="pe-preview-window">

                @* ── Background 1 preview ── *@
                @if (_tab == "bg")
                {
                    <div class="pe-pw-bg-wrap">
                        <div class="pe-pw-bg-layer" style="background:@GetPreviewBgCss(); opacity:@_bgOpacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture); background-size:@GetEffectiveBgSize(); background-position:@_bgPosition; background-repeat:no-repeat;"></div>
                        <div class="pe-pw-skeleton">
                            <div class="pe-pw-skel-nav"></div>
                            <div class="pe-pw-skel-hero">
                                <div class="pe-pw-skel-line pe-pw-skel-w60"></div>
                                <div class="pe-pw-skel-line pe-pw-skel-w40"></div>
                                <div class="pe-pw-skel-line pe-pw-skel-w50"></div>
                            </div>
                            <div class="pe-pw-skel-cards">
                                <div class="pe-pw-skel-card"></div>
                                <div class="pe-pw-skel-card"></div>
                                <div class="pe-pw-skel-card"></div>
                            </div>
                        </div>
                        <span class="pe-pw-chip">Background 1</span>
                    </div>
                }

                @* ── Background 2 (pattern) preview ── *@
                @if (_tab == "pattern")
                {
                    <div class="pe-pw-bg-wrap">
                        <div class="pe-pw-bg-layer" style="background:#07130a;"></div>
                        <div class="pe-pw-pattern-overlay pe-pw-pat-@_bgPattern"></div>
                        <div class="pe-pw-skeleton">
                            <div class="pe-pw-skel-nav"></div>
                        </div>
                        <span class="pe-pw-chip">Background 2 — @_bgPattern</span>
                    </div>
                }

                @* ── Navbar preview ── *@
                @if (_tab == "nav")
                {
                    <div class="pe-pw-nav-scene">
                        <div class="pe-pw-nav-bar" style="background:@GetNavbarPreviewColor()">
                            <svg xmlns="http://www.w3.org/2000/svg" class="pe-pw-nav-icon" viewBox="0 0 40 40">
                                <circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="2.5"/>
                                <text x="20" y="25" text-anchor="middle" font-size="13" font-weight="700" fill="currentColor">CE</text>
                            </svg>
                            <div class="pe-pw-nav-links">
                                <span>Home</span><span>News</span><span>Services</span><span>About</span>
                            </div>
                        </div>
                        <div class="pe-pw-nav-page-fill"></div>
                        <span class="pe-pw-chip">Navbar</span>
                    </div>
                }

                @* ── Header preview ── *@
                @if (_tab == "header")
                {
                    var previewLogoUrl = _logoPreviewDataUrl.Length > 0 ? _logoPreviewDataUrl
                        : (_hasHeaderLogo ? ApiEndpoints.SiteSettings.HeaderLogo : "");
                    var scaledLogoH = Math.Clamp((int)(_headerLogoHeight * 0.22), 8, 70);
                    <div class="pe-pw-header-scene">
                        @if (!string.IsNullOrEmpty(previewLogoUrl))
                        {
                            <img src="@previewLogoUrl" style="height:@(scaledLogoH)px; width:auto; object-fit:contain; margin-bottom:0.35rem;" alt="logo" />
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" class="pe-pw-header-default-icon" viewBox="0 0 60 60">
                                <circle cx="30" cy="30" r="27" fill="none" stroke="currentColor" stroke-width="3"/>
                                <text x="30" y="37" text-anchor="middle" font-size="16" font-weight="700" fill="currentColor">CE</text>
                            </svg>
                        }
                        <div class="pe-pw-header-orgname">@_headerOrgName</div>
                        <div class="pe-pw-header-quote">@_headerOrgQuote</div>
                        <span class="pe-pw-chip">Header</span>
                    </div>
                }

                @* ── Footer preview ── *@
                @if (_tab == "footer")
                {
                    <div class="pe-pw-footer-scene">
                        <div class="pe-pw-footer-spacer"></div>
                        <div class="pe-pw-footer-bar">
                            <div class="pe-pw-footer-left">
                                <svg xmlns="http://www.w3.org/2000/svg" class="pe-pw-footer-icon" viewBox="0 0 40 40">
                                    <circle cx="20" cy="20" r="16" fill="none" stroke="currentColor" stroke-width="2.5"/>
                                    <text x="20" y="25" text-anchor="middle" font-size="11" font-weight="700" fill="currentColor">CE</text>
                                </svg>
                                <div class="pe-pw-footer-text">
                                    <div class="pe-pw-footer-orgname">USJ-R COMPUTER ENGINEERING SOCIETY</div>
                                    <div class="pe-pw-footer-sub">@_footerOrgSub</div>
                                    <div class="pe-pw-footer-links-row">
                                        @if (!string.IsNullOrEmpty(_footerFacebookUrl) && _footerFacebookUrl != "#")
                                        { <span class="pe-pw-footer-link">&#x66;</span> }
                                    </div>
                                </div>
                            </div>
                            <div class="pe-pw-footer-right">
                                <span>Home</span><span>News Feed</span><span>Services</span><span>Officers</span><span>About Us</span>
                            </div>
                        </div>
                        <span class="pe-pw-chip">Footer</span>
                    </div>
                }

                @* ── Robot / Hero preview ── *@
                @if (_tab == "robot")
                {
                    <div class="pe-pw-robot-scene">
                        <div class="pe-pw-robot-adelante">@_robotAdelanteText</div>
                        <div class="pe-pw-robot-society">@_robotSocietyText</div>
                        <div class="pe-pw-robot-abbrev">@_robotAbbreviation</div>
                        <div class="pe-pw-robot-tagline">
                            @foreach (var line in (_robotTagline ?? "").Split('\n'))
                            {
                                <span>@line</span>
                            }
                        </div>
                        <span class="pe-pw-chip">Hero Section</span>
                    </div>
                }

                @* ── Theme preview ── *@
                @if (_tab == "theme")
                {
                    <div class="pe-pw-theme-scene" style="color:@_themeTextColor">
                        <div class="pe-pw-theme-title" style="color:@_themeAccent; font-family:@GetPreviewFontCss()">Theme Preview</div>
                        <div class="pe-pw-swatches-row">
                            <div class="pe-pw-swatch-item">
                                <div class="pe-pw-swatch" style="background:@_themeAccent"></div>
                                <span>Accent</span>
                            </div>
                            <div class="pe-pw-swatch-item">
                                <div class="pe-pw-swatch" style="background:@_themeAccentBright"></div>
                                <span>Bright</span>
                            </div>
                            <div class="pe-pw-swatch-item">
                                <div class="pe-pw-swatch" style="background:@_themeTextColor; border:1px solid rgba(255,255,255,0.2)"></div>
                                <span>Text</span>
                            </div>
                        </div>
                        <div class="pe-pw-font-sample" style="color:@_themeAccent; font-family:@GetPreviewFontCss(); font-size:@(_themeFontSize * 0.55)%">
                            Aa Bb Cc 123
                        </div>
                        <div class="pe-pw-font-label">@GetFontDisplayName()</div>
                        <div class="pe-pw-demo-btn" style="border-color:@_themeAccent; color:@_themeAccent; background:color-mix(in srgb, @_themeAccent 12%, transparent)">
                            Sample Button
                        </div>
                        <span class="pe-pw-chip">Theme</span>
                    </div>
                }

            </div><!-- /pe-preview-window -->
        </div><!-- /pe-preview-panel -->
    </div><!-- /pe-preview-column -->

    </div><!-- /pe-body -->

    <!-- ── ACTION BAR ── -->
    <div class="pe-action-bar">
        <button class="pe-btn-cancel" @onclick="CancelChanges">Cancel</button>
        <button class="pe-btn-default" @onclick="() => _showDefaultConfirm = true">Restore to Default</button>
        @if (CanDirectSave)
        {
            <button class="pe-btn-save" @onclick="() => _showSaveConfirm = true">Save Changes</button>
        }
        else
        {
            <button class="pe-btn-save" @onclick="() => _showProposeConfirm = true" disabled="@_saving">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:4px;"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                Submit for Approval
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(_saveStatus))
    {
        <div class="pe-save-status @(_saveError ? "error" : "success")">@_saveStatus</div>
    }
</div>

<!-- Save confirmation modal -->
@if (_showSaveConfirm)
{
    <div class="pe-modal-overlay" @onclick="() => _showSaveConfirm = false">
        <div class="pe-modal" @onclick:stopPropagation>
            <h3 class="pe-modal-title">Apply Settings?</h3>
            <p class="pe-modal-body">These settings will be applied site-wide for all visitors. Continue?</p>
            <div class="pe-modal-actions">
                <button class="pe-btn-cancel" @onclick="() => _showSaveConfirm = false">No, Cancel</button>
                <button class="pe-btn-save" @onclick="SaveToDb" disabled="@_saving">
                    @(_saving ? "Saving..." : "Yes, Save")
                </button>
            </div>
        </div>
    </div>
}

<!-- Propose for approval modal -->
@if (_showProposeConfirm)
{
    <div class="pe-modal-overlay" @onclick="() => _showProposeConfirm = false">
        <div class="pe-modal" @onclick:stopPropagation>
            <h3 class="pe-modal-title">Submit for Approval?</h3>
            <p class="pe-modal-body">Your changes will be submitted to the adviser for review. They won't go live until approved.</p>
            <div class="pe-modal-actions">
                <button class="pe-btn-cancel" @onclick="() => _showProposeConfirm = false">Cancel</button>
                <button class="pe-btn-save" @onclick="ProposeChanges" disabled="@_saving">
                    @(_saving ? "Submitting…" : "Submit")
                </button>
            </div>
        </div>
    </div>
}

<!-- Restore-to-default confirmation modal -->
@if (_showDefaultConfirm)
{
    <div class="pe-modal-overlay" @onclick="() => _showDefaultConfirm = false">
        <div class="pe-modal" @onclick:stopPropagation>
            <h3 class="pe-modal-title">Restore Defaults?</h3>
            <p class="pe-modal-body">This will submit a proposal to reset ALL appearance settings to the original defaults. An adviser must approve before changes go live.</p>
            <div class="pe-modal-actions">
                <button class="pe-btn-cancel" @onclick="() => _showDefaultConfirm = false">No, Cancel</button>
                <button class="pe-btn-default" @onclick="RestoreDefaults" disabled="@_saving">
                    @(_saving ? "Submitting..." : "Submit for Approval")
                </button>
            </div>
        </div>
    </div>
}

