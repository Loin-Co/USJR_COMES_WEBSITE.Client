        ThemeTextColor      = _themeTextColor,
        ThemeFontFamily     = _themeFontFamily,
        ThemeFontSize       = _themeFontSize,
    };

    private async Task ProposeChanges()
    {
        _showProposeConfirm = false;
        var bgValue = _bgType == "gradient"
            ? (_gradientPresets.FirstOrDefault(g => g.Key == _activeKey)?.Value ?? _gradientPresets[0].Value)
            : _bgColor;

        var req = new SiteSettingsRequest
        {
            BackgroundType          = _bgType,
            BackgroundValue         = bgValue,
            BackgroundOpacity       = _bgOpacity,
            BackgroundSize          = GetEffectiveBgSize(),
            BackgroundCustomSize    = _bgSize == "custom" ? GetEffectiveBgSize() : "",
            BackgroundPosition      = _bgPosition,
            NavbarColor             = _navbarColor,
            HeaderOrgName           = _headerOrgName,
            HeaderOrgQuote          = _headerOrgQuote,
            BackgroundImageBase64   = _bgImageBase64,
            BackgroundImageMimeType = _bgImageMimeType,
            ClearBackgroundImage    = _clearBgImage,
            HeaderLogoBase64        = _logoBase64,
            HeaderLogoMimeType      = _logoMimeType,
            ClearHeaderLogo         = _clearHeaderLogo,
            HeaderLogoHeight        = _headerLogoHeight,
            FooterLogoHeight        = _footerLogoHeight,
            BackgroundPattern       = _bgPattern,
            FooterOrgSub            = _footerOrgSub,
            FooterFacebookUrl       = _footerFacebookUrl,
            FooterWebsiteUrl        = _footerWebsiteUrl,
            RobotAdelanteText       = _robotAdelanteText,
            RobotSocietyText        = _robotSocietyText,
            RobotAbbreviation       = _robotAbbreviation,
            RobotTagline            = _robotTagline,
            ThemeAccent             = _themeAccent,
            ThemeAccentBright       = _themeAccentBright,
            ThemeTextColor          = _themeTextColor,
            ThemeFontFamily         = _themeFontFamily,
            ThemeFontSize           = _themeFontSize,
        };

        await SubmitProposal(req);
    }

    private async Task SubmitProposal(SiteSettingsRequest req)
    {
        _saving = true;
        _saveStatus = "";
        StateHasChanged();

        var proposedJson = System.Text.Json.JsonSerializer.Serialize(req);
        var payload = new
        {
            changeType         = "SiteSettings",
            proposedDataJson   = proposedJson,
            proposedBySchoolId = UserState.CurrentUser?.SchoolId ?? ""
        };

        var resp = await Http.PostAsJsonAsync(ApiEndpoints.SiteChanges.Propose, payload);
        _saving = false;

        if (resp.IsSuccessStatusCode)
        {
            _saveStatus = "Your changes have been submitted for adviser review.";
            _saveError = false;
        }
        else
        {
            _saveStatus = "Failed to submit. Please try again.";
            _saveError = true;
        }
    }

    private async Task SaveToDb()
    {
        _saving = true;
        _showSaveConfirm = false;
        _saveStatus = "";
        StateHasChanged();

        var bgValue = _bgType == "gradient"
            ? (_gradientPresets.FirstOrDefault(g => g.Key == _activeKey)?.Value ?? _gradientPresets[0].Value)
            : _bgColor;

        var req = new SiteSettingsRequest
        {
            BackgroundType          = _bgType,
            BackgroundValue         = bgValue,
            BackgroundOpacity       = _bgOpacity,
            BackgroundSize          = GetEffectiveBgSize(),
            BackgroundCustomSize    = _bgSize == "custom" ? GetEffectiveBgSize() : "",
            BackgroundPosition      = _bgPosition,
            NavbarColor             = _navbarColor,
            HeaderOrgName           = _headerOrgName,
            HeaderOrgQuote          = _headerOrgQuote,
            BackgroundImageBase64   = _bgImageBase64,
            BackgroundImageMimeType = _bgImageMimeType,
            ClearBackgroundImage    = _clearBgImage,
            HeaderLogoBase64        = _logoBase64,
            HeaderLogoMimeType      = _logoMimeType,
            ClearHeaderLogo         = _clearHeaderLogo,
            HeaderLogoHeight        = _headerLogoHeight,
            FooterLogoHeight        = _footerLogoHeight,
            BackgroundPattern       = _bgPattern,
            FooterOrgSub            = _footerOrgSub,
            FooterFacebookUrl       = _footerFacebookUrl,
            FooterWebsiteUrl        = _footerWebsiteUrl,
            RobotAdelanteText       = _robotAdelanteText,
            RobotSocietyText        = _robotSocietyText,
            RobotAbbreviation       = _robotAbbreviation,
            RobotTagline            = _robotTagline,
            ThemeAccent             = _themeAccent,
            ThemeAccentBright       = _themeAccentBright,
            ThemeTextColor          = _themeTextColor,
            ThemeFontFamily         = _themeFontFamily,
            ThemeFontSize           = _themeFontSize,
        };

        var ok = await SettingsService.SaveAsync(req);
        if (ok)
        {
            _saveStatus = "Settings saved successfully.";
            _saveError = false;
            _bgImageBase64 = null; _bgImageMimeType = null;
            _logoBase64 = null; _logoMimeType = null;
            _clearBgImage = false; _clearHeaderLogo = false;
            try
            {
                var s = SettingsService.Current;
                await JS.InvokeVoidAsync("bgCustomizer.applyFromSettings", new
                {
                    backgroundType       = s.BackgroundType,
                    backgroundValue      = s.BackgroundValue,
                    backgroundOpacity    = s.BackgroundOpacity,
                    backgroundSize       = s.BackgroundSize,
                    backgroundCustomSize = s.BackgroundCustomSize,
                    backgroundPosition   = s.BackgroundPosition,
                    navbarColor          = s.NavbarColor,
                    hasBackgroundImage   = s.HasBackgroundImage,
                    backgroundImageUrl   = ApiEndpoints.SiteSettings.BackgroundImage,
                    savedAt              = s.SavedAt,
                    backgroundPattern    = s.BackgroundPattern,
                });
                await JS.InvokeVoidAsync("themeCustomizer.apply", new
                {
                    themeAccent       = s.ThemeAccent,
                    themeAccentBright = s.ThemeAccentBright,
                    themeTextColor    = s.ThemeTextColor,
                    themeFontFamily   = s.ThemeFontFamily,
                    themeFontSize     = s.ThemeFontSize,
                });
                var bgSize = string.IsNullOrWhiteSpace(s.BackgroundCustomSize)
                    ? (s.BackgroundSize ?? "cover") : s.BackgroundCustomSize;
                var bgUrl = ApiEndpoints.SiteSettings.BackgroundImage + "?v=" + s.SavedAt;
                await JS.InvokeVoidAsync("bgCustomizer.syncServerLayer",
                    s.HasBackgroundImage, bgUrl, bgSize,
                    s.BackgroundPosition ?? "center",
                    s.BackgroundOpacity.ToString(System.Globalization.CultureInfo.InvariantCulture));
            }
            catch { }
        }
        else
        {
            _saveStatus = "Save failed. Please try again.";
            _saveError = true;
        }

        _saving = false;
    }

    private async Task CancelChanges()
    {
        await LoadFromService();
        _saveStatus = "";
    }

    private string GetPreviewBgCss()
    {
        if (_bgType == "image")
        {
            var url = !string.IsNullOrEmpty(_bgImagePreviewDataUrl)
                ? _bgImagePreviewDataUrl
                : (_hasBgImage ? ApiEndpoints.SiteSettings.BackgroundImage : "");
            return string.IsNullOrEmpty(url) ? _bgColor : $"url('{url}') center/cover no-repeat";
        }
        if (_bgType == "gradient")
            return _gradientPresets.FirstOrDefault(g => g.Key == _activeKey)?.Value ?? _gradientPresets[0].Value;
        return _bgColor;
    }

    private string GetNavbarPreviewColor() =>
        string.IsNullOrEmpty(_navbarColor) ? "rgba(7,20,12,0.92)" : _navbarColor;

