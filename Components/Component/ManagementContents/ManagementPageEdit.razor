        HasBackgroundImage  = _hasBgImage && string.IsNullOrEmpty(_bgImagePreviewDataUrl) || !string.IsNullOrEmpty(_bgImagePreviewDataUrl),
        HeaderLogoHeight    = _headerLogoHeight,
