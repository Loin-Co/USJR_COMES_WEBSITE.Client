@using Microsoft.AspNetCore.Components
@using USJR_COMES_WEBSITE.Services
@inject NavigationManager Nav
@inject UserStateService UserState

<div class="management-container">
    <aside class="management-sidebar">
        <div class="sidebar-role-badge">
            <span class="role-label">@GetRoleLabel()</span>
        </div>
        <ul class="management-menu">
            @if (IsOfficerOrAbove)
            {
                <li>
                    <a href="/management/posts" class="menu-item @(ActiveTab == "posts" ? "active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                        <span>Posts</span>
                    </a>
                </li>
                <li>
                    <a href="/management/events" class="menu-item @(ActiveTab == "events" ? "active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        <span>Events</span>
                    </a>
                </li>
                <li>
                    <a href="/management/services" class="menu-item @(ActiveTab == "services" ? "active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
                        <span>Services</span>
                    </a>
                </li>
                <li>
                    <a href="/management/aboutus" class="menu-item @(ActiveTab == "aboutus" ? "active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                        <span>About Us</span>
                    </a>
                </li>
                <li>
                    <a href="/management/officers" class="menu-item @(ActiveTab == "officers" ? "active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        <span>Officers</span>
                    </a>
                </li>
                <li>
                    <a href="/management/members" class="menu-item @(ActiveTab == "members" ? "active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        <span>Members</span>
                    </a>
                </li>
            }

            @if (IsBudgetUser)
            {
                <li>
                    <a href="/management/budget" class="menu-item @(ActiveTab == "budget" ? "active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                        <span>Budget</span>
                    </a>
                </li>
            }

            @if (IsAdviserOrAbove)
            {
                <li>
                    <a href="/management/approvals" class="menu-item @(ActiveTab == "approvals" ? "active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><polyline points="20 6 9 17 4 12"/></svg>
                        <span>Approvals</span>
                    </a>
                </li>
                <li>
                    <a href="/management/advisers" class="menu-item @(ActiveTab == "advisers" ? "active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><path d="M12 2a5 5 0 1 0 0 10A5 5 0 0 0 12 2zm0 12c-5.33 0-8 2.67-8 4v2h16v-2c0-1.33-2.67-4-8-4z"/><path d="M17 8l2 2 4-4"/></svg>
                        <span>Advisers</span>
                    </a>
                </li>
                <li>
                    <a href="/management/csvimport" class="menu-item @(ActiveTab == "csvimport" ? "active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                        <span>CSV Import</span>
                    </a>
                </li>
            }

            @if (IsPageEditUser)
            {
                <li>
                    <a href="/management/pageedit" class="menu-item @(ActiveTab == "pageedit" ? "active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
                        <span>Page Edit</span>
                    </a>
                </li>
            }
        </ul>
    </aside>

    <div class="management-mainarea">
        @if (ActiveTab == "posts")
        {
            <ManagementPosts />
        }
        else if (ActiveTab == "events")
        {
            <ManagementEvents />
        }
        else if (ActiveTab == "services")
        {
            <ManagementServices />
        }
        else if (ActiveTab == "aboutus")
        {
            <ManagementAboutUs />
        }
        else if (ActiveTab == "officers")
        {
            <ManagementOfficers />
        }
        else if (ActiveTab == "members")
        {
            <ManagementMembers />
        }
        else if (ActiveTab == "approvals")
        {
            <ManagementApprovals />
        }
        else if (ActiveTab == "budget" && IsBudgetUser)
        {
            <ManagementBudget ViewOnly="@IsBudgetViewOnly" />
        }
        else if (ActiveTab == "advisers" && IsAdviserOrAbove)
        {
            <ManagementAdvisers />
        }
        else if (ActiveTab == "csvimport" && IsAdviserOrAbove)
        {
            <ManagementCsvImport />
        }
        else if (ActiveTab == "pageedit" && IsPageEditUser)
        {
            <ManagementPageEdit />
        }
        else
        {
            @if (IsOfficerOrAbove)
            {
                <ManagementPosts />
            }
            else if (IsAdviserOrAbove)
            {
                <ManagementApprovals />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                    <p>You do not have management access.</p>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public string? PageType { get; set; }

    private string ActiveTab => string.IsNullOrEmpty(PageType) ? "" : PageType.ToLower();

    private string Role => UserState.CurrentUser?.AccountRole.ToString() ?? "NonMember";

    private bool IsOfficerOrAbove =>
        Role is "Officer" or "Adviser" or "Professor" or "DepartmentChairman" or "Admin";

    private bool IsAdviserOrAbove =>
        Role is "Adviser" or "DepartmentChairman" or "Admin";

    private bool IsDeptChairOrAdmin =>
        Role is "DepartmentChairman" or "Admin";

    private bool IsBudgetUser =>
        Role is "Officer" or "Adviser" or "DepartmentChairman" or "Admin";

    private bool IsBudgetViewOnly => Role is "Adviser";

    private bool IsPageEditUser =>
        Role is "Officer" or "Adviser" or "Professor" or "DepartmentChairman" or "Admin";

    private string GetRoleLabel() => Role switch
    {
        "Officer" => "Officer",
        "Adviser" => "Adviser",
        "DepartmentChairman" => "Dept. Chairman",
        "Admin" => "Admin",
        "Professor" => "Professor",
        _ => Role
    };
}
