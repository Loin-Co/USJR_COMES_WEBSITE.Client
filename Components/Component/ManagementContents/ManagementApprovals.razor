    private async Task LoadReceiptAsync(int transactionId)
    {
        _previewReceiptLoading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var resp = await Http.GetAsync($"api/Budget/transactions/{transactionId}/receipt");
            if (resp.IsSuccessStatusCode)
            {
                var bytes = await resp.Content.ReadAsByteArrayAsync();
                var mime  = resp.Content.Headers.ContentType?.MediaType ?? "application/octet-stream";
                if (bytes.Length > 0)
                {
                    _previewReceiptMime = mime;
                    _previewReceiptSrc  = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
                }
            }
        }
        catch { }
        _previewReceiptLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task<string?> FetchAsDataUrlAsync(string relativeOrDataUrl)
    {
        if (string.IsNullOrEmpty(relativeOrDataUrl)) return null;
        if (relativeOrDataUrl.StartsWith("data:", StringComparison.OrdinalIgnoreCase)) return relativeOrDataUrl;
        try
        {
            var fullUrl = ApiEndpoints.Files.ToFullUrl(relativeOrDataUrl);
            var resp    = await Http.GetAsync(fullUrl);
            if (!resp.IsSuccessStatusCode) return null;
            var bytes = await resp.Content.ReadAsByteArrayAsync();
            if (bytes.Length == 0) return null;
            var mime = resp.Content.Headers.ContentType?.MediaType ?? "image/png";
            return $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
        }
        catch { return null; }
    }

    // ── Site settings parsing ──────────────────────────────────────────────────

    private static SiteSettingsRequest? ParseSiteSettingsJson(string? json)
    {
        if (string.IsNullOrEmpty(json)) return null;
        try
        {
            return JsonSerializer.Deserialize<SiteSettingsRequest>(json,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }
        catch { return null; }
    }

    private static string BuildSitePreviewBgCss(SiteSettingsRequest s)
    {
        if (s.BackgroundType == "image" && !string.IsNullOrEmpty(s.BackgroundImageBase64) && !s.ClearBackgroundImage)
            return $"url('data:{s.BackgroundImageMimeType};base64,{s.BackgroundImageBase64}')";
        return s.BackgroundValue ?? "#07130a";
    }

