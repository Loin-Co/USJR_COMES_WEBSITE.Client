    // ── Image / receipt loading helpers ───────────────────────────────────────

    private async Task LoadPostImagesAsync(NewsFeedPostViewModel post)
    {
        var urls = (post.ImageUrl ?? "").Split(';', StringSplitOptions.RemoveEmptyEntries);
        if (urls.Length == 0) return;
        _previewImagesLoading = true;
        await InvokeAsync(StateHasChanged);
        var images = new List<string>();
        foreach (var url in urls.Take(4))
        {
            var dataUrl = await FetchAsDataUrlAsync(url.Trim());
            if (dataUrl != null) images.Add(dataUrl);
        }
        _previewImages = images;
        _previewImagesLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadEventImageAsync(UpcomingEventViewModel ev)
    {
        if (string.IsNullOrEmpty(ev.ImageUrl)) return;
        _previewImagesLoading = true;
        await InvokeAsync(StateHasChanged);
        var dataUrl = await FetchAsDataUrlAsync(ev.ImageUrl);
        if (dataUrl != null) _previewImages.Add(dataUrl);
        _previewImagesLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadServiceImageAsync(ServiceOfferedViewModel svc)
    {
        if (string.IsNullOrEmpty(svc.ImageUrl)) return;
