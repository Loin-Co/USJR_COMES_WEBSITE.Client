@if (ViewModel.IsViewerOpen && ViewModel.ViewingRequest != null)
{
    var reqData = ViewModel.ViewingRequest.GetDynamicData();
    var hasAttachment = reqData.TryGetValue("Attachment", out var filename);
    reqData.TryGetValue("FileData", out var fileData);

    // displaySrc: prefer the server-fetched data URL, then any inline base64 in the response
    var displaySrc = !string.IsNullOrEmpty(_attachmentDataUrl) ? _attachmentDataUrl
        : !string.IsNullOrEmpty(fileData) ? fileData
        : ((filename != null && (filename.StartsWith("data:") || filename.StartsWith("http"))) ? filename : "");

    // Show "no file" only when not loading and nothing was fetched
    bool missingFileContents = !_attachmentLoading
        && (string.IsNullOrEmpty(displaySrc) || !string.IsNullOrEmpty(_attachmentFetchError))
        && !string.IsNullOrEmpty(filename)
        && !filename.StartsWith("http")
        && !filename.StartsWith("data:");

    var fn = filename ?? "";
    bool isPdf = hasAttachment && fn.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);
    bool isDocx = hasAttachment && (fn.EndsWith(".docx", StringComparison.OrdinalIgnoreCase) || fn.EndsWith(".doc", StringComparison.OrdinalIgnoreCase));
    bool isImg = hasAttachment && (fn.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || fn.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) || fn.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || fn.EndsWith(".webp", StringComparison.OrdinalIgnoreCase) || fn.EndsWith(".gif", StringComparison.OrdinalIgnoreCase));

    // Check for receipt/proof image (Payment type)
    var hasReceiptImage = reqData.TryGetValue("ReceiptImageUrl", out var receiptImageUrl) && !string.IsNullOrEmpty(receiptImageUrl);
    var receiptFullUrl = hasReceiptImage ? USJR_COMES_WEBSITE.APIs.ApiEndpoints.Files.ToFullUrl(receiptImageUrl!) : "";

    <div class="modal-overlay" @onclick="ViewModel.CloseViewer">
        <div class="modal-card viewer-modal-card" @onclick:stopPropagation="true">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h3 class="modal-title m-0">Viewing Request: @ViewModel.ViewingRequest.UserName</h3>
                <button class="btn-close btn-close-white" @onclick="ViewModel.CloseViewer"></button>
            </div>
            <div class="modal-body" style="padding: 20px;">

                <!-- Status Row -->
                <div class="viewer-status-row mb-3">
                    <span style="color:#afd94d; font-weight:700;">Status:</span>
                    <span class="badge @ViewModel.GetStatusClass(ViewModel.ViewingRequest.Status)" style="margin-left:0.5rem; font-size:0.85rem;">@ViewModel.ViewingRequest.Status</span>
                </div>

                <!-- Details Card -->
                <div class="viewer-details-card mb-3">
                    <div class="viewer-details-title">Details</div>
                    <div class="viewer-details-grid">
                        @foreach (var item in reqData)
                        {
                            if (item.Key != "FileData" && item.Key != "FileApiUrl" && item.Key != "Attachment" && item.Key != "ReceiptImageUrl")
                            {
                                <div class="viewer-detail-row">
                                    <span class="viewer-detail-key">@item.Key</span>
                                    <span class="viewer-detail-val">@item.Value</span>
                                </div>
                            }
                        }
                        @if (hasAttachment && !string.IsNullOrEmpty(filename))
                        {
                            <div class="viewer-detail-row">
                                <span class="viewer-detail-key">Attachment</span>
                                <span class="viewer-detail-val">@filename</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- File Preview (for file-upload type) -->
                @if (hasAttachment && !string.IsNullOrEmpty(filename))
                {
                    <div class="viewer-file-preview">
                        @if (_attachmentLoading)
                        {
                            <div class="viewer-file-missing">
                                <div class="spinner-border spinner-border-sm text-success" role="status"></div>
                                <p style="margin-top:0.5rem; color:rgba(255,255,255,0.6);">Loading attachment...</p>
                            </div>
                        }
                        else if (missingFileContents)
                        {
                            <div class="viewer-file-missing">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
                                @if (!string.IsNullOrEmpty(_attachmentFetchError))
                                {
                                    <p style="color:#ff6b6b; font-size:0.8rem;">@_attachmentFetchError</p>
                                }
                                else
                                {
                                    <p>No physical file attached for "@filename"</p>
                                }
                            </div>
                        }
                        else if (isPdf)
                        {
                            <object data="@displaySrc" type="application/pdf" class="viewer-file-frame">
                                <iframe src="@displaySrc" class="viewer-file-frame" style="border:none;"></iframe>
                            </object>
                        }
                        else if (isDocx)
                        {
                            @if (displaySrc.StartsWith("data:"))
                            {
                                <div class="viewer-file-missing">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                    <p>Word documents cannot be previewed inline.</p>
                                    <a href="@displaySrc" download="@filename" class="btn btn-sm btn-outline-theme mt-2">Download @filename</a>
                                </div>
                            }
                            else
                            {
                                <iframe src="https://view.officeapps.live.com/op/embed.aspx?src=@(System.Net.WebUtility.UrlEncode(displaySrc))" class="viewer-file-frame" style="border:none;"></iframe>
                            }
                        }
                        else if (isImg)
                        {
                            <img src="@displaySrc" class="viewer-img-preview" />
                        }
                        else
                        {
                            <div class="viewer-file-missing">
                                <a href="@displaySrc" download="@filename" class="btn btn-sm btn-outline-theme">Download @filename</a>
                            </div>
                        }
                    </div>
                }

                <!-- Receipt/Proof of Payment image (Payment type) -->
                @if (hasReceiptImage && !string.IsNullOrEmpty(receiptFullUrl))
                {
                    <div class="viewer-file-preview mt-2">
                        <div class="viewer-details-title mb-2">Proof of Payment</div>
                        <img src="@receiptFullUrl" class="viewer-img-preview" />
                    </div>
                }

            </div>
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="ViewModel.CloseViewer">Close View</button>
                @if (ViewModel.SelectedService != null && ViewModel.ViewingRequest.Status == "Pending")
                {
                    @if ((USJR_COMES_WEBSITE.ViewModels.ServiceType)ViewModel.SelectedService.ActionType == USJR_COMES_WEBSITE.ViewModels.ServiceType.FileUpload)
                    {
                        <button class="btn btn-success confirm-action-btn" @onclick="@(async () => { await ViewModel.ChangeRequestStatusAsync(ViewModel.ViewingRequest, "Printed"); ViewModel.CloseViewer(); })">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                            Confirm Printed
                        </button>
                    }
                    else if ((USJR_COMES_WEBSITE.ViewModels.ServiceType)ViewModel.SelectedService.ActionType == USJR_COMES_WEBSITE.ViewModels.ServiceType.Payment)
                    {
                        <button class="btn btn-success confirm-action-btn" @onclick="@(async () => { await ViewModel.ChangeRequestStatusAsync(ViewModel.ViewingRequest, "Verified"); ViewModel.CloseViewer(); })">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                            Verify Payment
                        </button>
                    }
                    else if ((USJR_COMES_WEBSITE.ViewModels.ServiceType)ViewModel.SelectedService.ActionType == USJR_COMES_WEBSITE.ViewModels.ServiceType.Inventory)
                    {
                        <button class="btn btn-success confirm-action-btn" @onclick="@(async () => { await ViewModel.ChangeRequestStatusAsync(ViewModel.ViewingRequest, "Completed"); ViewModel.CloseViewer(); })">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                            Confirm Order
                        </button>
                    }
                    else if ((USJR_COMES_WEBSITE.ViewModels.ServiceType)ViewModel.SelectedService.ActionType == USJR_COMES_WEBSITE.ViewModels.ServiceType.Appointment)
                    {
                        <button class="btn btn-success confirm-action-btn" @onclick="@(async () => { await ViewModel.ChangeRequestStatusAsync(ViewModel.ViewingRequest, "Confirmed"); ViewModel.CloseViewer(); })">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                            Approve Slot
                        </button>
                    }
                    else if ((USJR_COMES_WEBSITE.ViewModels.ServiceType)ViewModel.SelectedService.ActionType == USJR_COMES_WEBSITE.ViewModels.ServiceType.Clearance)
                    {
                        <button class="btn btn-success confirm-action-btn" @onclick="@(async () => { await ViewModel.ChangeRequestStatusAsync(ViewModel.ViewingRequest, "Cleared"); ViewModel.CloseViewer(); })">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                            Clear Request
                        </button>
                    }
                }
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm && ViewModel.SelectedService != null)
{
    <div class="modal-overlay" @onclick="CancelDeleteService">
        <div class="modal-card confirm-delete-card" @onclick:stopPropagation="true">
            <h3 class="modal-title text-danger">Delete Service?</h3>
            <div class="modal-body" style="padding:1rem 0;">
                <p>Are you sure you want to delete <strong>"@ViewModel.SelectedService.Name"</strong>?</p>
                <p class="text-muted small">All requests under this service will also be deleted. This cannot be undone.</p>
            </div>
            <div class="modal-actions" style="justify-content:center;">
                <button class="btn btn-secondary" @onclick="CancelDeleteService" disabled="@_isDeleting">Cancel</button>
                <button class="btn btn-danger" @onclick="ProceedDeleteService" disabled="@_isDeleting">
                    @if (_isDeleting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        <span>Deleting...</span>
                    }
                    else { <span>Delete</span> }
                </button>
            </div>
        </div>
    </div>
}

<SuccessPopup IsVisible="ViewModel.ShowSuccess"
              Message="@ViewModel.SuccessMessage"
              OnOkClick="ViewModel.HideSuccess" />

@code {
    private HttpClient Http => HttpClientFactory.CreateClient("general");
    private bool _mobileDrawerOpen = false;
    private bool _isSaving = false;
    private bool _isDeleting = false;
    private bool _isToggling = false;
    private bool _showDeleteConfirm = false;

    private async Task HandleAddService()
    {
        _isSaving = true;
        StateHasChanged();
        await Task.Delay(1); // flush render so spinner paints before API call
        await ViewModel.AddServiceAsync();
        _isSaving = false;
        ViewModel.ClearReloadFlag();
        StateHasChanged();
    }

    private async Task HandleUpdateService()
    {
        _isSaving = true;
        StateHasChanged();
        await Task.Delay(1); // flush render so spinner paints before API call
        await ViewModel.UpdateServiceAsync();
        _isSaving = false;
        ViewModel.ClearReloadFlag();
        StateHasChanged();
    }

    private async Task HandleTogglePublish()
    {
        _isToggling = true;
        StateHasChanged();
        await Task.Delay(1);
        await ViewModel.TogglePublishStatusAsync();
        _isToggling = false;
        StateHasChanged();
    }

    private void OpenDeleteServiceModal() { _showDeleteConfirm = true; }
    private void CancelDeleteService() { _showDeleteConfirm = false; }

    private async Task ProceedDeleteService()
    {
        _isDeleting = true;
        StateHasChanged();
        await Task.Delay(1);
        await ViewModel.DeleteSelectedServiceAsync();
        _showDeleteConfirm = false;
        _isDeleting = false;
        StateHasChanged();
    }

    private List<BudgetAccountItem>? _budgetAccounts;

    // Viewer attachment state — fetched server-side to avoid browser cross-origin issues
    private string _attachmentDataUrl = "";
    private bool _attachmentLoading = false;
    private int _attachmentFetchedForId = -1;
    private string _attachmentFetchError = "";

    private void SelectService(USJR_COMES_WEBSITE.ViewModels.ServiceOfferedViewModel svc)
    {
        ViewModel.SelectService(svc);
        _mobileDrawerOpen = false;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        ViewModel.OnChange += HandleViewModelChange;
        await ViewModel.InitializeAsync();
        await LoadBudgetAccounts();
    }

    public void Dispose()
    {
        ViewModel.OnChange -= HandleViewModelChange;
    }

    private void HandleViewModelChange()
    {
        if (!ViewModel.IsViewerOpen)
        {
            _attachmentDataUrl = "";
            _attachmentFetchedForId = -1;
            _attachmentLoading = false;
            _attachmentFetchError = "";
        }
        StateHasChanged();

        if (ViewModel.IsViewerOpen && ViewModel.ViewingRequest != null)
        {
            var reqData = ViewModel.ViewingRequest.GetDynamicData();
            bool hasAttachmentKey = reqData.ContainsKey("Attachment");
            int requestId = ViewModel.ViewingRequest.Id;

            if (hasAttachmentKey && requestId != _attachmentFetchedForId)
                _ = FetchAttachmentAsync(requestId, reqData);
        }
    }

    private async Task FetchAttachmentAsync(int requestId, Dictionary<string, string> reqData)
    {
        _attachmentLoading = true;
        _attachmentFetchedForId = requestId;
        _attachmentFetchError = "";
        await InvokeAsync(StateHasChanged);

        // If the response already contains an inline data URL (injected by backend), use it directly
        if (reqData.TryGetValue("AttachmentDataUrl", out var inlineDataUrl) && !string.IsNullOrEmpty(inlineDataUrl))
        {
            _attachmentDataUrl = inlineDataUrl;
            _attachmentLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        // Otherwise fetch from the files API
        try
        {
            var url = requestId > 0
                ? $"api/files/servicerequest/{requestId}"
                : "";

            if (string.IsNullOrEmpty(url))
            {
                _attachmentFetchError = $"Request ID is {requestId} (not saved yet?)";
                _attachmentDataUrl = "";
            }
            else
            {
                var response = await Http.GetAsync(url);
                if (response.IsSuccessStatusCode)
                {
                    var bytes = await response.Content.ReadAsByteArrayAsync();
                    var mime = response.Content.Headers.ContentType?.MediaType ?? "image/png";
                    if (bytes.Length > 0)
                        _attachmentDataUrl = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
                    else
                        _attachmentFetchError = $"Server returned 0 bytes (ID={requestId})";
                }
                else
                {
                    _attachmentFetchError = $"Server returned {(int)response.StatusCode} for request ID {requestId}";
                    _attachmentDataUrl = "";
                }
            }
        }
        catch (Exception ex)
        {
            _attachmentFetchError = $"Error: {ex.GetType().Name} — {ex.Message}";
            _attachmentDataUrl = "";
        }
        _attachmentLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadBudgetAccounts()
    {
        try
        {
            // Find the current academic year first, then fetch only its Program accounts
            var years = await Http.GetFromJsonAsync<List<BudgetYearItem>>(ApiEndpoints.Budget.Accounts.Replace("accounts", "years")) ?? new();
            var currentYearId = years.FirstOrDefault(y => y.IsCurrent)?.Id ?? years.FirstOrDefault()?.Id;

            var url = currentYearId.HasValue
                ? $"{ApiEndpoints.Budget.Accounts}?yearId={currentYearId}"
                : ApiEndpoints.Budget.Accounts;

            var all = await Http.GetFromJsonAsync<List<BudgetAccountItem>>(url) ?? new();
            _budgetAccounts = all.Where(a => a.AccountType == "Program").ToList();
        }
        catch { _budgetAccounts = new(); }
    }

    private async Task ExportCsvAsync()
    {
        if (ViewModel.SelectedService == null) return;
        var csv = ViewModel.GenerateCsv(ViewModel.CsvExportStatus);
        var statusLabel = ViewModel.CsvExportStatus == "All" ? "All" : ViewModel.CsvExportStatus;
        var filename = $"{ViewModel.SelectedService.Name}_{statusLabel}_{DateTime.Now:yyyyMMdd}.csv";
        await JS.InvokeVoidAsync("downloadCsv", filename, csv);
    }

    private class BudgetAccountItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string AccountType { get; set; } = string.Empty;
    }

    private class BudgetYearItem
    {
        public int Id { get; set; }
        public bool IsCurrent { get; set; }
    }
}
