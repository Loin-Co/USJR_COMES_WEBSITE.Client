<SuccessPopup IsVisible="_showSuccess" Message="@_successMessage" OnOkClick="() => _showSuccess = false" />

@code {
    [Parameter] public bool ViewOnly { get; set; }

    // â”€â”€ State â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private List<AcademicYearViewModel> _years = new();
    private AcademicYearViewModel? _selectedYear;

    private List<BudgetAccountViewModel> _accounts = new();
    private bool _loading = true;
    private BudgetAccountViewModel? _selectedAccount;

    private string _txTab = "overview";
    private string _programsTab = "active";
    private List<BudgetAccountViewModel> _pendingAccountsList = new();
    private bool _saving;

    // New Academic Year modal
    private bool _newYearModalOpen;
    private string _newYearLabel = "";
    private string _newYearError = "";

    // Transfer modal
    private bool _transferModalOpen;
    private bool _transferToNewYear = true;
    private string _transferNewLabel = "";
    private int _transferToYearId;
    private decimal _transferAmount;
    private string _transferError = "";

    // Program modal
    private bool _accountModalOpen;
    private bool _editingAccount;
    private BudgetAccountViewModel _accountForm = new();
    private string _accountError = "";

    // Transaction modal
    private bool _txModalOpen;
    private bool _editingTx;
    private BudgetTransactionViewModel _txForm = new();
    private string _txError = "";
    private string _txRequesterDisplay = "";

    // Delete
    private BudgetAccountViewModel? _deleteTarget;
    private BudgetTransactionViewModel? _deleteTxTarget;

    // Success popup
    private bool _showSuccess { get; set; }
    private string _successMessage = "Operation successful.";

    // Receipt upload
    private string _receiptUploadStatus = "";

    // â”€â”€ Computed â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private BudgetAccountViewModel? MainAccount => _accounts.FirstOrDefault(a => a.AccountType == "Main");
    private List<BudgetTransactionViewModel> MainDirectTransactions => MainAccount?.Transactions ?? new();
    private List<BudgetAccountViewModel> ProgramAccounts => _accounts.Where(a => a.AccountType == "Program").ToList();

    private decimal TotalAllIncome  => _accounts.Sum(a => a.TotalIncome);
    private decimal TotalAllExpense => _accounts.Sum(a => a.TotalExpense);
    private decimal NetBalance      => TotalAllIncome - TotalAllExpense;

    private IEnumerable<(string Category, decimal Total)> SelectedCategories =>
        _selectedAccount?.Transactions
            .Where(t => t.TransactionType == "Expense" && !string.IsNullOrEmpty(t.Category))
            .GroupBy(t => t.Category!).Select(g => (Category: g.Key, Total: g.Sum(t => t.Amount)))
            .OrderByDescending(g => g.Total)
        ?? Enumerable.Empty<(string, decimal)>();

    private IEnumerable<(string Category, decimal Total)> OverviewExpenseBreakdown =>
        MainDirectTransactions
            .Where(t => t.TransactionType == "Expense" && !string.IsNullOrEmpty(t.Category))
            .GroupBy(t => t.Category!).Select(g => (Category: g.Key, Total: g.Sum(t => t.Amount)))
            .OrderByDescending(g => g.Total);

    private List<(BudgetTransactionViewModel Tx, string AccountTitle)> AllTransactions =>
        _accounts
            .SelectMany(a => a.Transactions.Select(t => (Tx: t, AccountTitle: a.AccountType == "Main" ? "Overall" : a.Title)))
            .OrderByDescending(x => x.Tx.TransactionDate).ThenByDescending(x => x.Tx.Id)
            .ToList();

    // â”€â”€ Lifecycle â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;

        _years = await BudgetService.GetYearsAsync();

        if (!_years.Any())
        {
            var label = AutoYearLabel();
            var created = await BudgetService.CreateYearAsync(new AcademicYearViewModel { Label = label, IsCurrent = true });
            if (created != null) _years = await BudgetService.GetYearsAsync();
        }

        // Determine selected year: keep current selection if still valid, else pick the current/first
        if (_selectedYear != null)
            _selectedYear = _years.FirstOrDefault(y => y.Id == _selectedYear.Id) ?? _years.FirstOrDefault(y => y.IsCurrent) ?? _years.FirstOrDefault();
        else
            _selectedYear = _years.FirstOrDefault(y => y.IsCurrent) ?? _years.FirstOrDefault();

        await LoadAccountsAsync();
        _loading = false;
    }

    private async Task LoadAccountsAsync()
    {
        if (_selectedYear == null) { _accounts = new(); _pendingAccountsList = new(); return; }

        var approvedTask = BudgetService.GetAccountsAsync(_selectedYear.Id);
        var pendingTask  = BudgetService.GetPendingAccountsAsync();
        await Task.WhenAll(approvedTask, pendingTask);

        _accounts = await approvedTask;
        _pendingAccountsList = (await pendingTask)
            .Where(a => a.AcademicYearId == _selectedYear.Id)
            .ToList();

        if (!_accounts.Any(a => a.AccountType == "Main"))
        {
            await BudgetService.CreateAccountAsync(new BudgetAccountViewModel
            {
                Title = "Overall Fund",
                AccountType = "Main",
                AcademicYearId = _selectedYear.Id
            });
            _accounts = await BudgetService.GetAccountsAsync(_selectedYear.Id);
        }

        if (_selectedAccount != null)
            _selectedAccount = _accounts.FirstOrDefault(a => a.Id == _selectedAccount.Id);
    }

    private static string AutoYearLabel()
    {
        var now = DateTime.Now;
        var start = now.Month >= 6 ? now.Year : now.Year - 1;
        return $"{start}-{start + 1}";
    }

    // â”€â”€ Year selection â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private async Task OnYearChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var id)) return;
        _selectedYear = _years.FirstOrDefault(y => y.Id == id);
        _selectedAccount = null;
        _txTab = "overview";

        // Show loading immediately
        _loading = true;
        StateHasChanged();

        // Load accounts in background
        _ = LoadAccountsInBackground();
    }

    private async Task LoadAccountsInBackground()
    {
        await LoadAccountsAsync();
        _loading = false;
    }

    // â”€â”€ New Academic Year modal â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private void OpenNewYearModal()
    {
        _newYearLabel = "";
        _newYearError = "";
        _newYearModalOpen = true;
    }

    private void CloseNewYearModal() => _newYearModalOpen = false;

    private async Task SaveNewYear()
    {
        if (string.IsNullOrWhiteSpace(_newYearLabel)) { _newYearError = "Label is required."; return; }
        _saving = true;
        _newYearError = "";
        var created = await BudgetService.CreateYearAsync(new AcademicYearViewModel { Label = _newYearLabel.Trim() });
        _saving = false;
        if (created == null) { _newYearError = "Failed to create academic year."; return; }
        _newYearModalOpen = false;
        await LoadAsync();
        _successMessage = "Academic year created.";
        _showSuccess = true;
    }

    // â”€â”€ Transfer modal â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private void OpenTransferModal()
    {
        _transferToNewYear = true;
        _transferNewLabel = "";
        _transferToYearId = 0;
        _transferAmount = NetBalance > 0 ? NetBalance : 0;
        _transferError = "";
        _transferModalOpen = true;
    }

    private void CloseTransferModal() => _transferModalOpen = false;

    private async Task ProceedTransfer()
    {
        if (_transferAmount <= 0)
        {
            _transferError = "Transfer amount must be greater than zero."; return;
        }
        if (_transferAmount > NetBalance)
        {
            _transferError = $"Amount exceeds the net balance of â‚±{NetBalance.ToString("N2")}."; return;
        }
        if (_transferToNewYear && string.IsNullOrWhiteSpace(_transferNewLabel))
        {
            _transferError = "New year label is required."; return;
        }
        if (!_transferToNewYear && _transferToYearId == 0)
        {
            _transferError = "Please select a target academic year."; return;
        }

        _saving = true;
        _transferError = "";

        var result = await BudgetService.TransferBudgetAsync(new TransferBudgetViewModel
        {
            FromYearId = _selectedYear!.Id,
            ToYearId = _transferToNewYear ? 0 : _transferToYearId,
            NewYearLabel = _transferToNewYear ? _transferNewLabel.Trim() : null,
            CreatedBy = UserState.CurrentUser?.SchoolId,
            RequestedByName = GetRequesterDisplay(),
            Amount = _transferAmount
        });

        _saving = false;

        if (result == null) { _transferError = "Transfer failed. Please try again."; return; }

        _transferModalOpen = false;

        // Switch view to the new current year
        _selectedYear = null;
        await LoadAsync();
        _successMessage = "Budget transferred successfully.";
        _showSuccess = true;
    }

    // â”€â”€ Navigation â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private void SelectOverview() { _selectedAccount = null; _txTab = "overview"; }
    private void SelectAccount(BudgetAccountViewModel acct) { _selectedAccount = acct; _txTab = "overview"; }

    // â”€â”€ Program modal â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private void OpenAccountModal(bool editing, BudgetAccountViewModel? acct = null)
    {
        _editingAccount = editing;
        _accountError = "";
        _accountForm = editing && acct != null
            ? new BudgetAccountViewModel { Id = acct.Id, Title = acct.Title, Description = acct.Description, AccountType = acct.AccountType, TargetBudget = acct.TargetBudget, AcademicYearId = acct.AcademicYearId }
            : new BudgetAccountViewModel { AccountType = "Program", AcademicYearId = _selectedYear?.Id };
        _accountModalOpen = true;
    }

    private void CloseAccountModal() => _accountModalOpen = false;

    private async Task SaveAccount()
    {
        if (string.IsNullOrWhiteSpace(_accountForm.Title)) { _accountError = "Title is required."; return; }
        if (_accountForm.TargetBudget < 0) { _accountError = "Target budget cannot be negative."; return; }
        _saving = true;
        _accountError = "";
        _accountForm.CreatedBy = UserState.CurrentUser?.SchoolId;
        if (_editingAccount) await BudgetService.UpdateAccountAsync(_accountForm);
        else await BudgetService.CreateAccountAsync(_accountForm);
        _saving = false;
        _accountModalOpen = false;
        await LoadAccountsAsync();
        _successMessage = _editingAccount ? "Program updated successfully." : "Program submitted for adviser approval.";
        _showSuccess = true;
    }

    // â”€â”€ Transaction modal â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private string GetRequesterDisplay() =>
        UserState.CurrentUser is { } u && (!string.IsNullOrEmpty(u.FirstName) || !string.IsNullOrEmpty(u.LastName))
            ? $"{u.FirstName} {u.LastName}".Trim()
            : UserState.CurrentUser?.SchoolId ?? "Unknown";

    private void OpenOverallTxModal(string type)
    {
        _editingTx = false; _txError = ""; _receiptUploadStatus = "";
        _txRequesterDisplay = GetRequesterDisplay();
        _txForm = new BudgetTransactionViewModel { BudgetAccountId = MainAccount!.Id, TransactionDate = DateTime.Today.ToString("yyyy-MM-dd"), TransactionType = type };
        _txModalOpen = true;
    }

    private void OpenProgramTxModal(string type)
    {
        _editingTx = false; _txError = ""; _receiptUploadStatus = "";
        _txRequesterDisplay = GetRequesterDisplay();
        _txForm = new BudgetTransactionViewModel { BudgetAccountId = _selectedAccount!.Id, TransactionDate = DateTime.Today.ToString("yyyy-MM-dd"), TransactionType = type };
        _txModalOpen = true;
    }

    private void OpenEditTransactionModal(BudgetTransactionViewModel tx)
    {
        _editingTx = true; _txError = ""; _receiptUploadStatus = "";
        _txRequesterDisplay = tx.RequestedByName ?? tx.CreatedBy ?? GetRequesterDisplay();
        _txForm = new BudgetTransactionViewModel { Id = tx.Id, BudgetAccountId = tx.BudgetAccountId, Title = tx.Title, Description = tx.Description, Category = tx.Category, Amount = tx.Amount, TransactionType = tx.TransactionType, TransactionDate = tx.TransactionDate, CreatedBy = tx.CreatedBy, RequestedByName = tx.RequestedByName, HasReceipt = tx.HasReceipt };
        _txModalOpen = true;
    }

    private void CloseTxModal() { _txModalOpen = false; _receiptUploadStatus = ""; }

    private async Task HandleReceiptFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        _receiptUploadStatus = "Reading file...";
        try
        {
            using var ms = new System.IO.MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
            _txForm.ReceiptBase64 = Convert.ToBase64String(ms.ToArray());
            _txForm.ReceiptMimeType = file.ContentType;
            _receiptUploadStatus = $"Ready: {file.Name}";
        }
        catch
        {
            _receiptUploadStatus = "Failed â€” max 10 MB.";
        }
    }

    private async Task SaveTransaction()
    {
        if (string.IsNullOrWhiteSpace(_txForm.Title)) { _txError = "Reason is required."; return; }
        if (_txForm.Amount <= 0) { _txError = "Amount must be greater than zero."; return; }
        var hasExistingReceipt = _editingTx && _txForm.HasReceipt;
        if (!hasExistingReceipt && string.IsNullOrEmpty(_txForm.ReceiptBase64))
        {
            _txError = "A receipt or proof of transaction is required. Please upload an image or PDF.";
            return;
        }
        _saving = true; _txError = "";
        _txForm.CreatedBy = UserState.CurrentUser?.SchoolId;
        if (!_editingTx) _txForm.RequestedByName = GetRequesterDisplay();
        if (_editingTx) await BudgetService.UpdateTransactionAsync(_txForm);
        else await BudgetService.CreateTransactionAsync(_txForm);
        _saving = false; _txModalOpen = false;
        await LoadAccountsAsync();
        _successMessage = _editingTx ? "Transaction updated." : "Transaction submitted for adviser approval.";
        _showSuccess = true;
    }

    // â”€â”€ Delete â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private void ConfirmDeleteAccount(BudgetAccountViewModel acct) { _deleteTarget = acct; _deleteTxTarget = null; }
    private void ConfirmDeleteTransaction(BudgetTransactionViewModel tx) { _deleteTxTarget = tx; _deleteTarget = null; }
    private void CancelDelete() { _deleteTarget = null; _deleteTxTarget = null; }

    private async Task ProceedDelete()
    {
        if (_deleteTarget != null)
        {
            var acct = _deleteTarget;
            var idx = _accounts.IndexOf(acct);
            if (_selectedAccount?.Id == acct.Id) _selectedAccount = null;
            _accounts.Remove(acct);
            _deleteTarget = null;

            _saving = true;
            var ok = await BudgetService.DeleteAccountAsync(acct.Id);
            _saving = false;
            if (!ok) { _accounts.Insert(Math.Max(0, idx), acct); return; }
        }
        else if (_deleteTxTarget != null)
        {
            var tx = _deleteTxTarget;
            var parentAcct = _accounts.FirstOrDefault(a => a.Transactions?.Any(t => t.Id == tx.Id) == true);
            var txIdx = parentAcct?.Transactions?.IndexOf(tx) ?? -1;
            parentAcct?.Transactions?.Remove(tx);
            _deleteTxTarget = null;

            _saving = true;
            var ok = await BudgetService.DeleteTransactionAsync(tx.Id);
            _saving = false;
            if (!ok && parentAcct?.Transactions != null)
            {
                if (txIdx >= 0) parentAcct.Transactions.Insert(txIdx, tx);
                return;
            }
        }
        _successMessage = "Deleted successfully.";
        _showSuccess = true;
    }

    // â”€â”€ CSV Export â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    private async Task ExportOverviewToCsv()
    {
        if (MainAccount == null) return;
        await JS.InvokeVoidAsync("downloadCsv", $"overall-{_selectedYear?.Label}-{DateTime.Today:yyyy-MM-dd}.csv", BuildCsv(MainAccount, "Overall Fund"));
    }

    private async Task ExportProgramToCsv(BudgetAccountViewModel prog)
    {
        await JS.InvokeVoidAsync("downloadCsv", $"{prog.Title.Replace(" ", "-")}-{DateTime.Today:yyyy-MM-dd}.csv", BuildCsv(prog, prog.Title));
    }

    private string BuildCsv(BudgetAccountViewModel account, string label)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"Academic Year,{EscapeCsv(_selectedYear?.Label ?? "")}");
        sb.AppendLine($"Account,{EscapeCsv(label)}");
        if (account.AccountType == "Program" && account.TargetBudget > 0)
            sb.AppendLine($"Target Budget,{account.TargetBudget:N2}");
        sb.AppendLine($"Total Income,{account.TotalIncome:N2}");
        sb.AppendLine($"Total Expense,{account.TotalExpense:N2}");
        sb.AppendLine($"Balance,{account.Balance:N2}");
        sb.AppendLine();
        sb.AppendLine("Date,Reason,Type,Category,Amount,Description,Requested By,School ID");
        foreach (var tx in account.Transactions.OrderByDescending(t => t.TransactionDate))
            sb.AppendLine($"{tx.TransactionDate},{EscapeCsv(tx.Title)},{tx.TransactionType},{EscapeCsv(tx.Category ?? "")},{tx.Amount:N2},{EscapeCsv(tx.Description ?? "")},{EscapeCsv(tx.RequestedByName ?? "")},{EscapeCsv(tx.CreatedBy ?? "")}");
        return sb.ToString();
    }

    private static string EscapeCsv(string value)
    {
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n'))
            return $"\"{value.Replace("\"", "\"\"")}\"";
        return value;
    }

