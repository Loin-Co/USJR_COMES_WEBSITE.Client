@using USJR_COMES_WEBSITE.Services
@using USJR_COMES_WEBSITE.ViewModels
@using USJR_COMES_WEBSITE.APIs
@using Microsoft.AspNetCore.Components.Forms
@inject IBudgetService BudgetService
@inject UserStateService UserState
@inject IJSRuntime JS

<div class="budget-wrap">

    <!-- â”€â”€ Header â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <div class="budget-header">
        <div>
            <h2 class="budget-title">Budget & Finance</h2>
            <p class="budget-subtitle">Track cash flow, program allocations, and expenses</p>
        </div>
        <div class="budget-header-actions">
            @if (!ViewOnly)
            {
                <button class="btn-cash-in" @onclick='() => OpenOverallTxModal("Income")'>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Cash In
                </button>
                <button class="btn-cash-out" @onclick='() => OpenOverallTxModal("Expense")'>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Cash Out
                </button>
                <button class="btn-new-program" @onclick="() => OpenAccountModal(false)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    New Program
                </button>
            }
            <button class="btn-export" @onclick="ExportOverviewToCsv">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Export CSV
            </button>
        </div>
    </div>

    <!-- â”€â”€ Academic Year Bar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <div class="ay-bar">
        <div class="ay-bar-left">
            <span class="ay-label-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </span>
            <span class="ay-label-text">Academic Year</span>
            <select class="ay-select" value="@(_selectedYear?.Id ?? 0)" @onchange="OnYearChanged">
                @foreach (var y in _years)
                {
                    <option value="@y.Id">@y.Label @(y.IsCurrent ? "(Current)" : "")</option>
                }
            </select>
            @if (_selectedYear?.IsCurrent == true)
            {
                <span class="ay-current-badge">Active</span>
            }
            else if (_selectedYear != null)
            {
                <span class="ay-past-badge">Past</span>
            }
        </div>
        <div class="ay-bar-right">
            @if (!ViewOnly)
            {
                <button class="btn-ay-new" @onclick="OpenNewYearModal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    New A.Y.
                </button>
                @if (_selectedYear != null && NetBalance != 0)
                {
                    <button class="btn-ay-transfer" @onclick="OpenTransferModal">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        Transfer Budget
                    </button>
                }
            }
        </div>
    </div>

    @if (_loading)
    {
        <SkeletonBudgetRow Count="4" />
    }
    else if (_selectedYear == null)
    {
        <div class="budget-no-year">
            <p>No academic year yet.</p>
            <button class="bgt-btn-save" @onclick="OpenNewYearModal">Create First Academic Year</button>
        </div>
    }
    else
    {
        <div class="budget-summary-row">
            <div class="summary-card cashin-card">
                <div class="summary-label">Total Cash In</div>
                <div class="summary-amount income-color">â‚±@TotalAllIncome.ToString("N2")</div>
                <div class="summary-sub">
                    <span class="income-dot"></span>
                    Overall + @ProgramAccounts.Count program(s)
                </div>
            </div>
            <div class="summary-card cashout-card">
                <div class="summary-label">Total Cash Out</div>
                <div class="summary-amount expense-color">â‚±@TotalAllExpense.ToString("N2")</div>
                <div class="summary-sub">
                    <span class="expense-dot"></span>
                    Overall + @ProgramAccounts.Count program(s)
                </div>
            </div>
            <div class="summary-card net-card">
                <div class="summary-label">Net Balance</div>
                <div class="summary-amount @(NetBalance < 0 ? "negative" : "")">â‚±@NetBalance.ToString("N2")</div>
                <div class="summary-sub">@ProgramAccounts.Count program(s)</div>
            </div>
        </div>

        @if (NetBalance < 0)
        {
            <div class="budget-warning">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                Overall cash out exceeds cash in by â‚±@(Math.Abs(NetBalance).ToString("N2")). Record any missing income entries.
            </div>
        }

        <!-- â”€â”€ Two-panel layout â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        <div class="budget-panels">

            <!-- Left: Programs -->
            <div class="accounts-panel">
                <div class="accounts-panel-header" style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">
                    <span>Programs</span>
                    <div class="prog-tab-bar">
                        <button class="prog-tab @(_programsTab == "active" ? "prog-tab-active" : "")" @onclick='() => _programsTab = "active"'>
                            Active
                            @if (ProgramAccounts.Any()) { <span class="prog-tab-count">@ProgramAccounts.Count</span> }
                        </button>
                        <button class="prog-tab @(_programsTab == "pending" ? "prog-tab-active" : "")" @onclick='() => _programsTab = "pending"'>
                            Pending
                            @if (_pendingAccountsList.Any()) { <span class="prog-tab-count prog-tab-count-pending">@_pendingAccountsList.Count</span> }
                        </button>
                    </div>
                </div>

                @if (_programsTab == "active")
                {
                    <!-- Overall Fund entry -->
                    <div class="account-item @(_selectedAccount == null ? "selected" : "")" @onclick="SelectOverview">
                        <div class="account-item-top">
                            <span class="account-icon main-icon">âˆ‘</span>
                            <div>
                                <div class="account-name">Overall Fund</div>
                                <div class="account-type-label">All programs combined</div>
                            </div>
                        </div>
                        <div class="account-cashflow-row">
                            <span class="acf-in">+â‚±@TotalAllIncome.ToString("N2")</span>
                            <span class="acf-sep">/</span>
                            <span class="acf-out">âˆ’â‚±@TotalAllExpense.ToString("N2")</span>
                            <span class="acf-net @(NetBalance < 0 ? "negative" : "")">= â‚±@NetBalance.ToString("N2")</span>
                        </div>
                    </div>

                    @foreach (var prog in ProgramAccounts)
                    {
                        bool overSpent = prog.TargetBudget > 0 && prog.TotalExpense > prog.TargetBudget;
                        <div class="account-item @(_selectedAccount?.Id == prog.Id ? "selected" : "") @(overSpent ? "over-budget" : "")" @onclick="() => SelectAccount(prog)">
                            <div class="account-item-top">
                                <span class="account-icon @(prog.EventId.HasValue ? "event-icon" : "prog-icon")">
                                    @(prog.EventId.HasValue ? "E" : "P")
                                </span>
                                <div style="flex:1;min-width:0;">
                                    <div class="account-name">@prog.Title</div>
                                    <div class="account-type-label" style="display:flex;align-items:center;gap:0.35rem;">
                                        @if (prog.EventId.HasValue) { <span class="event-acct-tag">Event Budget</span> }
                                        else { <span>Program</span> }
                                        @if (prog.TargetBudget > 0) { <span>Â· Target â‚±@prog.TargetBudget.ToString("N2")</span> }
                                    </div>
                                </div>
                            </div>
                            <div class="account-cashflow-row">
                                <span class="acf-in">+â‚±@prog.TotalIncome.ToString("N2")</span>
                                <span class="acf-sep">/</span>
                                <span class="acf-out">âˆ’â‚±@prog.TotalExpense.ToString("N2")</span>
                                <span class="acf-net @(prog.Balance < 0 ? "negative" : "")">= â‚±@prog.Balance.ToString("N2")</span>
                            </div>
                            @if (prog.TargetBudget > 0)
                            {
                                var pct = Math.Min(100m, prog.TotalExpense / prog.TargetBudget * 100);
                                <div class="prog-bar-wrap">
                                    <div class="prog-bar"><div class="prog-bar-fill @(pct >= 100 ? "full" : "")" style="width:@pct.ToString("0")%"></div></div>
                                    <div class="prog-bar-label">Spent â‚±@prog.TotalExpense.ToString("N2") / â‚±@prog.TargetBudget.ToString("N2")</div>
                                </div>
                            }
                            @if (overSpent) { <div class="prog-warn-label">âš  Over target budget</div> }
                            @if (!ViewOnly)
                            {
                                <div class="account-item-actions">
                                    <button class="acct-btn-edit" @onclick:stopPropagation="true" @onclick="() => OpenAccountModal(true, prog)">Edit</button>
                                    @if (!prog.EventId.HasValue)
                                    {
                                        <button class="acct-btn-del" @onclick:stopPropagation="true" @onclick="() => ConfirmDeleteAccount(prog)">Del</button>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (!ProgramAccounts.Any())
                    {
                        <div class="accounts-empty">No programs yet. Create one to track sub-budgets.</div>
                    }
                }
                else
                {
                    @if (!_pendingAccountsList.Any())
                    {
                        <div class="accounts-empty">No programs pending approval.</div>
                    }
                    else
                    {
                        @foreach (var prog in _pendingAccountsList)
                        {
                            <div class="account-item" style="opacity:0.75;cursor:default;">
                                <div class="account-item-top">
                                    <span class="account-icon prog-icon">P</span>
                                    <div style="flex:1;min-width:0;">
                                        <div class="account-name">@prog.Title</div>
                                        <div class="account-type-label" style="display:flex;align-items:center;gap:0.35rem;">
                                            <span>Program</span>
                                            @if (prog.TargetBudget > 0) { <span>Â· Target â‚±@prog.TargetBudget.ToString("N2")</span> }
                                        </div>
                                    </div>
                                    <span style="font-size:10px;padding:2px 8px;border-radius:10px;background:rgba(245,158,11,.15);color:#f59e0b;font-weight:600;white-space:nowrap;">Pending</span>
                                </div>
                                @if (!string.IsNullOrEmpty(prog.Description))
                                {
                                    <div class="account-type-label" style="margin-top:0.25rem;font-size:11px;">@prog.Description</div>
                                }
                                @if (!string.IsNullOrEmpty(prog.CreatedBy))
                                {
                                    <div class="account-type-label" style="margin-top:0.2rem;font-size:11px;">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="vertical-align:middle;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                        @prog.CreatedBy
                                    </div>
                                }
                            </div>
                        }
                    }
                }
            </div>

            <!-- Right: Transactions -->
            <div class="transactions-panel">

                <div class="tx-tabs">
                    <button class="tx-tab @(_txTab == "overview" ? "active" : "")" @onclick='() => _txTab = "overview"'>
                        @(_selectedAccount != null ? _selectedAccount.Title : "Overview")
                    </button>
                    <button class="tx-tab @(_txTab == "all" ? "active" : "")" @onclick='() => _txTab = "all"'>
                        All Transactions
                        <span class="tx-tab-count">@_accounts.Sum(a => a.Transactions.Count)</span>
                    </button>
                </div>

                @if (_txTab == "overview")
                {
                    @if (_selectedAccount == null)
                    {
                        <div class="tx-panel-header">
                            <div>
                                <div class="tx-panel-title">Overall Fund</div>
                                <div class="tx-panel-sub">@MainDirectTransactions.Count direct transaction(s)</div>
                            </div>
                            @if (!ViewOnly)
                            {
                                <div class="tx-panel-actions">
                                    <button class="btn-add-tx btn-cashin-sm" @onclick='() => OpenOverallTxModal("Income")'>+ Cash In</button>
                                    <button class="btn-add-tx btn-cashout-sm" @onclick='() => OpenOverallTxModal("Expense")'>âˆ’ Cash Out</button>
                                </div>
                            }
                        </div>

                        @if (OverviewExpenseBreakdown.Any())
                        {
                            <div class="expense-breakdown">
                                <div class="breakdown-label">Direct Expense Breakdown</div>
                                <div class="breakdown-chips">
                                    @foreach (var cat in OverviewExpenseBreakdown)
                                    {
                                        <span class="breakdown-chip">@cat.Category: â‚±@cat.Total.ToString("N2")</span>
                                    }
                                </div>
                            </div>
                        }

                        @if (!MainDirectTransactions.Any())
                        {
                            <div class="tx-empty">No direct transactions yet. Use Cash In / Cash Out above.</div>
                        }
                        else
                        {
                            <div class="tx-list">
                                @foreach (var tx in MainDirectTransactions.OrderByDescending(t => t.TransactionDate).ThenByDescending(t => t.Id))
                                {
                                    @TxRow(tx)
                                }
                            </div>
                        }

                        @if (ProgramAccounts.Any())
                        {
                            <div class="prog-breakdown-section">
                                <div class="prog-breakdown-header">Program Breakdown</div>
                                @foreach (var prog in ProgramAccounts)
                                {
                                    <div class="prog-breakdown-row" @onclick="() => SelectAccount(prog)">
                                        <div class="prog-bd-left">
                                            <span class="account-icon @(prog.EventId.HasValue ? "event-icon" : "prog-icon") prog-bd-icon">@(prog.EventId.HasValue ? "E" : "P")</span>
                                            <span class="prog-bd-name">@prog.Title</span>
                                        </div>
                                        <div class="prog-bd-flow">
                                            <span class="acf-in">+â‚±@prog.TotalIncome.ToString("N2")</span>
                                            <span class="acf-sep">/</span>
                                            <span class="acf-out">âˆ’â‚±@prog.TotalExpense.ToString("N2")</span>
                                            <span class="acf-net @(prog.Balance < 0 ? "negative" : "")">= â‚±@prog.Balance.ToString("N2")</span>
                                        </div>
                                    </div>
                                }
                                @{
                                    var progIn  = ProgramAccounts.Sum(p => p.TotalIncome);
                                    var progOut = ProgramAccounts.Sum(p => p.TotalExpense);
                                    var progNet = ProgramAccounts.Sum(p => p.Balance);
                                }
                                <div class="prog-breakdown-total">
                                    <span class="prog-bd-total-label">All Programs</span>
                                    <div class="prog-bd-flow">
                                        <span class="acf-in">+â‚±@progIn.ToString("N2")</span>
                                        <span class="acf-sep">/</span>
                                        <span class="acf-out">âˆ’â‚±@progOut.ToString("N2")</span>
                                        <span class="acf-net @(progNet < 0 ? "negative" : "")">= â‚±@progNet.ToString("N2")</span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="tx-panel-header">
                            <div>
                                <div class="tx-panel-title">@_selectedAccount.Title</div>
                                <div class="tx-panel-sub">@_selectedAccount.Transactions.Count transaction(s)</div>
                            </div>
                            <div class="tx-panel-actions">
                                @if (!ViewOnly)
                                {
                                    <button class="btn-add-tx btn-cashin-sm" @onclick='() => OpenProgramTxModal("Income")'>+ Cash In</button>
                                    <button class="btn-add-tx btn-cashout-sm" @onclick='() => OpenProgramTxModal("Expense")'>âˆ’ Cash Out</button>
                                }
                                <button class="acct-btn-export" @onclick="() => ExportProgramToCsv(_selectedAccount)">CSV</button>
                            </div>
                        </div>

                        @if (SelectedCategories.Any())
                        {
                            <div class="expense-breakdown">
                                <div class="breakdown-label">Expense Breakdown</div>
                                <div class="breakdown-chips">
                                    @foreach (var cat in SelectedCategories) { <span class="breakdown-chip">@cat.Category: â‚±@cat.Total.ToString("N2")</span> }
                                </div>
                            </div>
                        }

                        @if (!_selectedAccount.Transactions.Any())
                        {
                            <div class="tx-empty">No transactions yet for this program.</div>
                        }
                        else
                        {
                            <div class="tx-list">
                                @foreach (var tx in _selectedAccount.Transactions.OrderByDescending(t => t.TransactionDate).ThenByDescending(t => t.Id))
                                {
                                    @TxRow(tx)
                                }
                            </div>
                        }
                    }
                }
                else
                {
                    <div class="tx-panel-header">
                        <div>
                            <div class="tx-panel-title">Transaction History</div>
                            <div class="tx-panel-sub">All Â· @_accounts.Sum(a => a.Transactions.Count) record(s)</div>
                        </div>
                    </div>
                    @if (!AllTransactions.Any())
                    {
                        <div class="tx-empty">No transactions recorded yet.</div>
                    }
                    else
                    {
                        <div class="tx-list">
                            @foreach (var item in AllTransactions)
                            {
                                <div class="tx-row">
                                    <div class="tx-type-dot @(item.Tx.TransactionType == "Income" ? "income-dot-lg" : "expense-dot-lg")"></div>
                                    <div class="tx-info">
                                        <div class="tx-title">@item.Tx.Title</div>
                                        <div class="tx-meta">
                                            @item.Tx.TransactionDate
                                            <span class="tx-acct-chip">@item.AccountTitle</span>
                                            @if (!string.IsNullOrEmpty(item.Tx.Category)) { <span class="tx-cat-chip">@item.Tx.Category</span> }
                                            @if (!string.IsNullOrEmpty(item.Tx.Description)) { <span class="tx-desc">Â· @item.Tx.Description</span> }
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.Tx.RequestedByName))
                                        {
                                            <div class="tx-requester">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                                @item.Tx.RequestedByName
                                                @if (!string.IsNullOrEmpty(item.Tx.CreatedBy)) { <span class="tx-school-id">(@item.Tx.CreatedBy)</span> }
                                            </div>
                                        }
                                    </div>
                                    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
                                        <div class="tx-amount @(item.Tx.TransactionType == "Income" ? "income-amount" : "expense-amount")">
                                            @(item.Tx.TransactionType == "Income" ? "+" : "âˆ’")â‚±@item.Tx.Amount.ToString("N2")
                                        </div>
                                        @if (item.Tx.ApprovalStatus == "Pending")
                                        {
                                            <span style="font-size:10px;padding:2px 8px;border-radius:10px;background:rgba(245,158,11,.15);color:#f59e0b;font-weight:600;">Pending</span>
                                        }
                                        else if (item.Tx.ApprovalStatus == "Approved")
                                        {
                                            <span style="font-size:10px;padding:2px 8px;border-radius:10px;background:rgba(34,197,94,.12);color:#22c55e;font-weight:600;">Approved</span>
                                        }
                                        else if (item.Tx.ApprovalStatus == "Rejected")
                                        {
                                            <span style="font-size:10px;padding:2px 8px;border-radius:10px;background:rgba(239,68,68,.12);color:#ef4444;font-weight:600;" title="@item.Tx.RejectionReason">Rejected</span>
                                        }
                                    </div>
                                    <div class="tx-actions">
                                        @if (item.Tx.HasReceipt)
                                        {
                                            <a href="@ApiEndpoints.Budget.TransactionReceipt(item.Tx.Id)" target="_blank" class="tx-btn-receipt" title="View receipt">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                                            </a>
                                        }
                                        @if (!ViewOnly)
                                        {
                                            <button class="tx-btn-edit" @onclick="() => OpenEditTransactionModal(item.Tx)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            </button>
                                            <button class="tx-btn-del" @onclick="() => ConfirmDeleteTransaction(item.Tx)">
