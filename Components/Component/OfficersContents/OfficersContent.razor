@using USJR_COMES_WEBSITE.Services
@using USJR_COMES_WEBSITE.ViewModels
@using USJR_COMES_WEBSITE.APIs
@inject IOfficersService OfficersService
@inject HttpClient Http

<div class="org-chart-wrapper">
    <h1 class="org-chart-title">COMES ORGANIZATIONAL CHART @(string.IsNullOrEmpty(AcademicYear) ? "" : $"- A.Y. {AcademicYear}")</h1>

    <div class="officers-list">
        @if (Officers == null)
        {
            <SkeletonOfficerCard Count="3" />
        }
        else if (Officers.Count == 0)
        {
            <p>No officers found for this academic year.</p>
        }
        else
        {
            @foreach (var (officer, index) in Officers.Select((o, i) => (o, i)))
            {
                <div class="officer-card @(index % 2 == 0 ? "image-left" : "image-right")">
                    <div class="officer-image-col">
                        <div class="officer-image-box">
                            <img src="@GetOfficerImage(officer)" alt="@officer.Name" class="officer-img" loading="lazy" />
                        </div>
                    </div>
                    <div class="officer-text">
                        <p class="officer-quote">"@officer.Quote"</p>
                        <p class="officer-name">@officer.Name</p>
                        <p class="officer-position">@officer.Position, USJ-R COMPUTER ENGINEERING SOCIETY</p>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public string? AcademicYear { get; set; }

    private List<OfficerViewModel>? Officers;
    private List<string> _allYears = new();
    private string _activeYear = string.Empty;

    // Cache of ImageUrl → data: URL (or fallback path)
    private Dictionary<string, string> _imageCache = new();

    private const string FallbackImage = "images/person.svg";

    /// <summary>
    /// Returns the cached data: URL for officers with photos,
    /// or the generic person placeholder if none uploaded.
    /// Never points the browser directly at the backend.
    /// </summary>
    private string GetOfficerImage(OfficerViewModel officer)
    {
        if (string.IsNullOrWhiteSpace(officer.ImageUrl)) return FallbackImage;
        return _imageCache.TryGetValue(officer.ImageUrl, out var cached) ? cached : FallbackImage;
    }

    /// <summary>
    /// Fetches all officer images from the API server-side (in WASM context)
    /// and converts them to base64 data: URLs so the browser never makes
    /// unauthenticated direct requests to the backend file endpoint.
    /// </summary>
    private async Task LoadOfficerImagesAsync()
    {
        if (Officers == null) return;

        var tasks = Officers
            .Where(o => !string.IsNullOrWhiteSpace(o.ImageUrl) && !_imageCache.ContainsKey(o.ImageUrl!))
            .Select(async o =>
            {
                try
                {
                    var url   = ApiEndpoints.Files.ToFullUrl(o.ImageUrl!);
                    var bytes = await Http.GetByteArrayAsync(url);
                    var ext   = o.ImageUrl!.Split('.').LastOrDefault()?.ToLower() ?? "jpeg";
                    var mime  = ext switch
                    {
                        "png"  => "image/png",
                        "gif"  => "image/gif",
                        "webp" => "image/webp",
                        _      => "image/jpeg"
                    };
                    _imageCache[o.ImageUrl!] = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
                }
                catch
                {
                    // Image unavailable — fall back to generic placeholder
                    _imageCache[o.ImageUrl!] = FallbackImage;
                }
            });

        await Task.WhenAll(tasks);
        StateHasChanged();
    }

    private string? _loadedForYear;

    protected override void OnParametersSet()
    {
        var incoming = AcademicYear ?? "";
        if (incoming == _loadedForYear) return;
        Officers = null;
        _imageCache.Clear();
        _ = LoadDataInBackground();
    }

    private async Task LoadDataInBackground()
    {
        if (!string.IsNullOrEmpty(AcademicYear))
        {
            // Year is already known from the URL — fetch years list AND officers in parallel.
            var yearsTask    = OfficersService.GetAcademicYearsAsync();
            var officersTask = OfficersService.GetOfficersByYearAsync(AcademicYear);
            await Task.WhenAll(yearsTask, officersTask);
            _allYears   = yearsTask.Result ?? new List<string>();
            _activeYear = AcademicYear;
            Officers    = officersTask.Result;
        }
        else
        {
            // No year in URL — must fetch years first to know which year to load.
            _allYears   = (await OfficersService.GetAcademicYearsAsync()) ?? new List<string>();
            _activeYear = _allYears.FirstOrDefault() ?? string.Empty;
            await LoadOfficers();
        }

        _loadedForYear = _activeYear;
        StateHasChanged();

        // Now fetch all officer images server-side → data: URLs
        await LoadOfficerImagesAsync();
    }

    private async Task SwitchYear(string year)
    {
        _activeYear = year;
        _imageCache.Clear();
        await LoadOfficers();
        StateHasChanged();
        await LoadOfficerImagesAsync();
    }

    private async Task LoadOfficers()
    {
        if (string.IsNullOrEmpty(_activeYear))
        {
            Officers = new();
            return;
        }
        Officers = await OfficersService.GetOfficersByYearAsync(_activeYear);
    }
}
