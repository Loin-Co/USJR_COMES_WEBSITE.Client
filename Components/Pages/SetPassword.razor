@page "/set-password"
@inject NavigationManager NavigationManager
@inject USJR_COMES_WEBSITE.Services.IUserServices UserServices

<div class="sp-page">
    <div class="sp-card">

        @if (_done)
        {
            <div class="sp-state-icon">
                <div class="sp-icon-wrap success">
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#6ed42a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                </div>
            </div>
            <p class="sp-state-heading">Password Set Successfully!</p>
            <p class="sp-state-body">You can now log in with your student ID and new password.</p>
            <a href="/login" class="sp-btn-outline">Go to Login</a>
        }
        else if (_tokenInvalid)
        {
            <div class="sp-state-icon">
                <div class="sp-icon-wrap error">
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="15" y1="9" x2="9" y2="15"/>
                        <line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                </div>
            </div>
            <p class="sp-state-heading">Invalid or Expired Link</p>
            <p class="sp-state-body">This link has expired or has already been used. Request a new link from the login page.</p>
            <a href="/login" class="sp-btn-outline">Back to Login</a>
        }
        else
        {
            <h1 class="sp-title">@(_isReset ? "Reset Password" : "Set Your Password")</h1>

            @if (_errorMessage is not null)
            {
                <p class="sp-error">@_errorMessage</p>
            }

            <div class="sp-fields">
                <label class="sp-label">New Password</label>
                <input class="sp-input" type="password" placeholder="Enter new password"
                       @bind="_newPassword" />

                <label class="sp-label">Confirm Password</label>
                <input class="sp-input" type="password" placeholder="Confirm new password"
                       @bind="_confirmPassword" />
            </div>

            <button class="sp-btn" @onclick="HandleSubmit" disabled="@_submitting">
                @(_submitting ? "Setting password…" : "Set Password")
            </button>
        }

    </div>
</div>

@code {
    private string? _token;
    private string _newPassword    = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _errorMessage;
    private bool _submitting  = false;
    private bool _done        = false;
    private bool _tokenInvalid = false;
    private bool _isReset     = false;

    protected override void OnInitialized()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        // WASM-compatible query string parsing
        var queryParams = uri.Query.TrimStart('?')
            .Split('&', StringSplitOptions.RemoveEmptyEntries)
            .Select(p => p.Split('=', 2))
            .Where(p => p.Length == 2)
            .ToDictionary(
                p => Uri.UnescapeDataString(p[0]),
                p => Uri.UnescapeDataString(p[1]),
                StringComparer.OrdinalIgnoreCase);

        queryParams.TryGetValue("token", out _token);

        queryParams.TryGetValue("reset", out var resetVal);
        _isReset = resetVal == "true";

        if (string.IsNullOrEmpty(_token))
            _tokenInvalid = true;
    }

    private async Task HandleSubmit()
    {
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            _errorMessage = "Please enter a new password.";
            return;
        }
        if (_newPassword.Length < 6)
        {
            _errorMessage = "Password must be at least 6 characters.";
            return;
        }
        if (_newPassword != _confirmPassword)
        {
            _errorMessage = "Passwords do not match.";
            return;
        }

        _submitting = true;
        var (success, error) = await UserServices.CompletePasswordSetupAsync(_token!, _newPassword);
        _submitting = false;

        if (success)
        {
            _done = true;
        }
        else
        {
            if (error?.Contains("Invalid") == true || error?.Contains("expired") == true)
                _tokenInvalid = true;
            else
                _errorMessage = error ?? "An error occurred. Please try again.";
        }
    }
}
